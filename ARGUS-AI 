CYTHON_PYX = '''
# argus_cext.pyx — Extensions C pour ARGUS v9
from libc.math cimport log2
from libc.string cimport memset
import numpy as np

cpdef double c_entropy_bytes(bytes data):
    cdef int counts[256]
    cdef int n = len(data)
    cdef double p, r = 0.0
    cdef int i
    if n == 0: return 0.0
    memset(counts, 0, sizeof(counts))
    for i in range(n): counts[<unsigned char>data[i]] += 1
    for i in range(256):
        if counts[i] > 0:
            p = counts[i] / <double>n
            r -= p * log2(p)
    return r

cpdef double c_entropy_str(str s):
    cdef int n = len(s)
    cdef double p, r = 0.0
    if n == 0: return 0.0
    freq = {}
    for ch in s: freq[ch] = freq.get(ch, 0) + 1
    for count in freq.values():
        p = count / <double>n
        r -= p * log2(p)
    return r

cpdef double c_consonant_ratio(str s):
    cdef int alpha = 0, cons = 0
    for ch in s.lower():
        if ch.isalpha():
            alpha += 1
            if ch not in "aeiou": cons += 1
    return cons / <double>alpha if alpha > 0 else 0.0

cpdef bint c_nop_sled(bytes data, int threshold=16):
    cdef int count = 0, i, n = len(data)
    for i in range(n):
        if <unsigned char>data[i] == 0x90:
            count += 1
            if count >= threshold: return True
        else:
            count = 0
    return False

cpdef tuple c_parse_ja3_fields(bytes payload):
    cdef int length = len(payload), offset, session_len
    cdef int cipher_len, comp_len, ext_total, end
    cdef int ext_type, ext_len, version, i
    cdef list ciphers = [], exts = []
    if length < 5 or <unsigned char>payload[0] != 0x16:
        return (None, None, None)
    version = (<unsigned char>payload[1] << 8) | <unsigned char>payload[2]
    offset = 43
    if offset >= length: return (None, None, None)
    session_len = <unsigned char>payload[offset]
    offset += 1 + session_len
    if offset + 2 > length: return (None, None, None)
    cipher_len = (<unsigned char>payload[offset] << 8) | <unsigned char>payload[offset+1]
    offset += 2
    for i in range(0, cipher_len, 2):
        if offset+i+2 <= length:
            ciphers.append(str((<unsigned char>payload[offset+i]<<8)|<unsigned char>payload[offset+i+1]))
    offset += cipher_len
    if offset < length:
        comp_len = <unsigned char>payload[offset]
        offset += 1 + comp_len
    if offset + 2 <= length:
        ext_total = (<unsigned char>payload[offset]<<8)|<unsigned char>payload[offset+1]
        offset += 2; end = offset + ext_total
        while offset + 4 <= end and offset + 4 <= length:
            ext_type = (<unsigned char>payload[offset]<<8)|<unsigned char>payload[offset+1]
            ext_len  = (<unsigned char>payload[offset+2]<<8)|<unsigned char>payload[offset+3]
            exts.append(str(ext_type)); offset += 4 + ext_len
    return (str(version), ",".join(ciphers), ",".join(exts))

cpdef bint c_is_dns_tunnel(str label, int min_len=45):
    cdef int n = len(label)
    if n < min_len: return False
    cdef double ent = c_entropy_str(label)
    cdef double cr  = c_consonant_ratio(label)
    return ent > 3.8 and cr > 0.72
