class TrafficSimulator:
    BENIGN  = ["google.com","github.com","microsoft.com","stackoverflow.com","ubuntu.com"]
    SUSPECT = ["ajd92kd83k.com","x7f2k9pq1m3v.net","a1b2c3d4e5f6.xyz"]
    C2      = "c2.beacon-hidden.io"
    TLS_FPS = ["modern_browser_tls","a0e9f5d64349fb13191bc781f81f42e1",
               "6bea65232c1288defa4bf058f5e99601","unknown_tls_lib"]
    IPS_EXT = ["185.220.101.1","94.102.49.12","91.108.4.11","45.33.32.156"]
    IPS_INT = ["10.0.0.10","192.168.1.42","172.16.3.7","10.10.10.99"]
    MACS    = ["aa:bb:cc:11:22:33","de:ad:be:ef:00:01","11:22:33:44:55:66"]
    BSSIDS  = ["00:11:22:33:44:55","aa:bb:cc:dd:ee:ff"]
    SSIDS   = ["FreeWifi","MonReseau","ARGUS-Lab","Corp-WiFi"]
    WIFI_TYPES = ["wifi_deauth","wifi_probe","wifi_evil_twin","wifi_handshake","wifi_pmkid","arp_spoofing"]
    SCAN_TYPES  = ["port_scan","ssh_bruteforce","http_sqli","http_xss","http_path_traversal"]
    EXFIL_TYPES = ["dns_tunnel","data_exfil","lateral_movement"]

    def __init__(self, pipeline, interval=1.5):
        self.pipeline = pipeline; self.interval = interval
        self._stop = threading.Event()
        self.log = logging.getLogger("ARGUS.Sim")

    def _event(self):
        r = random.random()
        if r < 0.15:
            # Wi-Fi
            wtype = random.choice(self.WIFI_TYPES)
            alerts = [Alert(
                type=wtype, severity=random.choice(["HIGH","CRITICAL","MEDIUM"]),
                confidence="medium", source="wlan1",
                bssid=random.choice(self.BSSIDS), ssid=random.choice(self.SSIDS),
                mac_src=random.choice(self.MACS), channel=random.randint(1,13),
                rssi=random.randint(-90,-30),
                detail=f"[SIM] {wtype}",
            )]
            self.pipeline._enqueue(alerts)
        elif r < 0.30:
            # Scan / Brute-force
            stype = random.choice(self.SCAN_TYPES)
            ip    = random.choice(self.IPS_EXT)
            alerts = [Alert(
                type=stype, severity="HIGH", confidence="high",
                source_ip=ip, source="wlan0",
                detail=f"[SIM] {stype} depuis {ip}",
                http_method="GET" if "http" in stype else None,
                http_uri="/admin?id=1 UNION SELECT 1,2,3--" if stype=="http_sqli" else None,
            )]
            self.pipeline._enqueue(alerts)
        elif r < 0.45:
            # Exfiltration / Latéral
            etype = random.choice(self.EXFIL_TYPES)
            ip    = random.choice(self.IPS_INT)
            alerts = [Alert(
                type=etype, severity="CRITICAL", confidence="high",
                source_ip=ip, source="wlan0",
                bytes_out=random.randint(1024*1024, 100*1024*1024),
                detail=f"[SIM] {etype} depuis {ip}",
            )]
            self.pipeline._enqueue(alerts)
        else:
            # Trafic réseau standard
            dom = (self.C2 if r<0.55 else
                   random.choice(self.SUSPECT) if r<0.70 else
                   random.choice(self.BENIGN))
            fp  = random.choice(self.TLS_FPS)
            ip  = random.choice(self.IPS_EXT + self.IPS_INT)
            self.pipeline.process_synthetic(dom, fp, ip)

    def start(self):
        self.log.info("Simulateur actif | intervalle=%.1fs", self.interval)
        while not self._stop.is_set():
            try: self._event()
            except Exception as e: self.log.error("Sim : %s", e)
            time.sleep(self.interval)

    def stop(self): self._stop.set()


