class IncidentPlaybook:
    """
    Exécute des playbooks de réponse automatisés selon le type d'alerte :
    - Blocage IP automatique
    - Notification webhook/Slack/email
    - Création de règles YARA dynamiques
    - Escalade vers SOC
    - Honeypot redirect
    - Documentation d'incident
    """
    PLAYBOOKS = {
        "port_scan":        ["log_incident","throttle_ip","notify_soc"],
        "ssh_bruteforce":   ["log_incident","block_ip","notify_soc","add_ioc"],
        "http_sqli":        ["log_incident","block_ip","notify_soc"],
        "http_rce":         ["log_incident","block_ip","notify_soc","escalate"],
        "cve_exploit":      ["log_incident","block_ip","notify_soc","escalate","pcap_start"],
        "backdoor_behavior":["log_incident","block_ip","notify_soc","escalate"],
        "dns_tunnel":       ["log_incident","block_ip","notify_soc"],
        "data_exfil":       ["log_incident","block_ip","notify_soc","escalate"],
        "lateral_movement": ["log_incident","isolate_segment","notify_soc","escalate"],
        "wifi_evil_twin":   ["log_incident","deauth_rogue","notify_soc"],
        "wifi_deauth":      ["log_incident","notify_soc"],
        "threat_intel_hit": ["log_incident","block_ip","notify_soc","add_ioc"],
        "dns_beaconing":    ["log_incident","block_ip","notify_soc"],
        "dga_domain":       ["log_incident","notify_soc","add_ioc"],
        "default":          ["log_incident"],
    }

    def __init__(self, config: Dict, iface_mgr: KaliInterfaceManager,
                 db: "DatabaseManager", ti: "ThreatIntelligence"):
        self.cfg         = config.get("playbook", {})
        self.enabled     = self.cfg.get("enabled", True)
        self.auto_isolate = self.cfg.get("auto_isolate", False)
        self.webhook     = self.cfg.get("notify_webhook", "")
        self.slack       = self.cfg.get("notify_slack", "")
        self.iface       = iface_mgr
        self.db          = db
        self.ti          = ti
        self.log         = logging.getLogger("ARGUS.Playbook")
        self._executed:  Dict[str, int] = defaultdict(int)  # incident_id → actions_count
        self._history:   deque = deque(maxlen=1000)

    def execute(self, alert: Alert, iface_mgr: KaliInterfaceManager) -> List[str]:
        if not self.enabled: return []
        steps    = self.PLAYBOOKS.get(alert.type, self.PLAYBOOKS["default"])
        executed = []
        for step in steps:
            fn = getattr(self, f"_step_{step}", None)
            if fn:
                try:
                    result = fn(alert, iface_mgr)
                    if result: executed.append(f"{step}:{result}")
                except Exception as e:
                    self.log.error("Playbook step %s : %s", step, e)
        inc = (alert.brain or {}).get("incident_id","?")
        self._executed[inc] += len(executed)
        self._history.append({"ts":time.time(),"incident":inc,
                              "type":alert.type,"steps":executed})
        return executed

    def _step_log_incident(self, alert: Alert, iface_mgr) -> str:
        report_dir = Path("output/incidents")
        report_dir.mkdir(parents=True, exist_ok=True)
        inc = (alert.brain or {}).get("incident_id", "UNK")
        fname = report_dir / f"{inc}_{alert.type}.json"
        fname.write_text(json.dumps(alert.to_dict(), indent=2))
        return f"logged:{fname.name}"

    def _step_block_ip(self, alert: Alert, iface_mgr: KaliInterfaceManager) -> str:
        ip = alert.source_ip
        if not ip: return ""
        if iface_mgr.block_ip(ip, f"Playbook:{alert.type}"):
            self.db.add_blocked_ip(ip, f"Auto-block: {alert.type}", expires_h=24)
            return f"blocked:{ip}"
        return ""

    def _step_throttle_ip(self, alert: Alert, iface_mgr: KaliInterfaceManager) -> str:
        ip = alert.source_ip
        if not ip: return ""
        if iface_mgr.throttle_ip(ip, kbps=128):
            return f"throttled:{ip}"
        return ""

    def _step_isolate_segment(self, alert: Alert, iface_mgr: KaliInterfaceManager) -> str:
        if not self.auto_isolate: return "isolation:manual_required"
        ip = alert.source_ip
        if ip:
            iface_mgr.block_ip(ip, f"Isolation:{alert.type}")
            return f"isolated:{ip}"
        return ""

    def _step_notify_soc(self, alert: Alert, iface_mgr) -> str:
        if not (self.webhook or self.slack): return "no_webhook_configured"
        payload = {
            "text": f"🚨 ARGUS IDS Alert | {alert.severity} | {alert.type}",
            "attachments": [{
                "color": "danger" if alert.severity in ("CRITICAL","HIGH") else "warning",
                "fields": [
                    {"title":"Type",     "value":alert.type,           "short":True},
                    {"title":"Severity", "value":alert.severity,       "short":True},
                    {"title":"Source IP","value":alert.source_ip or "?","short":True},
                    {"title":"MITRE",    "value":alert.mitre_id,       "short":True},
                    {"title":"Detail",   "value":alert.detail[:200],   "short":False},
                ]
            }]
        }
        target = self.slack or self.webhook
        if REQUESTS_OK and target:
            try:
                http_req.post(target, json=payload, timeout=5)
                return f"notified:{target[:30]}"
            except Exception as e:
                return f"notify_failed:{e}"
        return "requests_unavailable"

    def _step_escalate(self, alert: Alert, iface_mgr) -> str:
        inc = (alert.brain or {}).get("incident_id", "UNK")
        self.log.critical(
            "🔴 ESCALADE SOC | %s | %s | %s | %s",
            inc, alert.severity, alert.type,
            alert.source_ip or alert.domain or "?"
        )
        return f"escalated:{inc}"

    def _step_add_ioc(self, alert: Alert, iface_mgr) -> str:
        if alert.source_ip and not FastMath.is_private_ip(alert.source_ip):
            self.ti.add_ioc("ip", alert.source_ip, source=f"auto:{alert.type}")
            return f"ioc_added:{alert.source_ip}"
        if alert.domain:
            self.ti.add_ioc("domain", alert.domain, source=f"auto:{alert.type}")
            return f"ioc_added:{alert.domain}"
        return ""

    def _step_deauth_rogue(self, alert: Alert, iface_mgr: KaliInterfaceManager) -> str:
        if alert.bssid and alert.mac_src:
            iface_mgr.deauth_station(alert.bssid, alert.mac_src)
            return f"deauth:{alert.bssid}"
        return ""

    def _step_pcap_start(self, alert: Alert, iface_mgr) -> str:
        return "pcap:auto_capture_active"

    @property
    def recent_actions(self) -> List[Dict]:
        return list(self._history)[-20:]


