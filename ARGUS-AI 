class ReportGenerator:
    def __init__(self, config: Dict, db: DatabaseManager):
        self.config     = config
        self.db         = db
        self.report_dir = Path(config.get("report_dir", "output/reports"))
        self.report_dir.mkdir(parents=True, exist_ok=True)
        self.log        = logging.getLogger("ARGUS.Report")

    def generate_html(self, blocks: List[Dict] = None) -> str:
        stats = self.db.recent_stats()
        attackers = self.db.get_top_attackers(limit=10)
        blocked   = self.db.get_active_blocks()

        # Stats de base
        total    = stats.get("total", 0)
        by_sev   = stats.get("by_severity", {})
        by_geo   = stats.get("by_country", {})
        critical = by_sev.get("CRITICAL", 0)
        high     = by_sev.get("HIGH", 0)

        # Rows HTML
        HIGH_RISK = {"CN","RU","KP","IR","SY","CU","SD"}
        geo_rows = "\n".join(
            f"<tr><td>{c}</td><td>{n}</td>"
            f"<td class='{'CRITICAL' if c in HIGH_RISK else 'LOW'}'>{'⚠ HIGH RISK' if c in HIGH_RISK else 'Normal'}</td></tr>"
            for c, n in sorted(by_geo.items(), key=lambda x: -x[1])[:10]
        )

        attacker_rows = "\n".join(
            f"<tr><td><code>{a['ip']}</code></td><td>{a.get('country','?')}</td>"
            f"<td>{a['count']}</td><td>{a.get('max_risk','?')}</td></tr>"
            for a in attackers
        )

        # Dernières alertes critiques depuis SIEM
        siem = Path(self.config.get("siem_file","output/siem_export.jsonl"))
        recent_alerts = []
        if siem.exists():
            lines = siem.read_text(encoding="utf-8").strip().split("\n")
            for l in reversed(lines[-200:]):
                try:
                    d = json.loads(l)
                    if d.get("severity") in ("CRITICAL","HIGH"):
                        recent_alerts.append(d)
                        if len(recent_alerts) >= 20: break
                except: pass

        alert_rows = "\n".join(
            f"<tr><td>{a.get('timestamp_iso','?')[:19]}</td>"
            f"<td>{a.get('type','?')}</td>"
            f"<td class='{a.get('severity','LOW')}'>{a.get('severity','?')}</td>"
            f"<td>{a.get('source_ip','?')}</td>"
            f"<td>{a.get('mitre_id','?')}</td>"
            f"<td>{str(a.get('detail',''))[:80]}</td></tr>"
            for a in recent_alerts
        )

        block_rows = "\n".join(
            f"<tr><td><code>{b['ip']}</code></td>"
            f"<td>{b.get('reason','?')[:60]}</td>"
            f"<td>{datetime.fromtimestamp(b.get('blocked_at',0)).strftime('%Y-%m-%d %H:%M')}</td></tr>"
            for b in blocked[:20]
        )

        html = REPORT_HTML_TEMPLATE
        html = html.replace("{{generated_at}}", datetime.now().isoformat())
        html = html.replace("{{total}}", str(total))
        html = html.replace("{{critical}}", str(critical))
        html = html.replace("{{high}}", str(high))
        html = html.replace("{{blocked}}", str(len(blocked)))
        html = html.replace("{{geo_rows}}", geo_rows)
        html = html.replace("{{attacker_rows}}", attacker_rows)
        html = html.replace("{{alert_rows}}", alert_rows)
        html = html.replace("{{block_rows}}", block_rows)

        fname = self.report_dir / f"report_{datetime.now().strftime('%Y%m%d_%H%M%S')}.html"
        fname.write_text(html, encoding="utf-8")
        self.log.info("Rapport généré : %s", fname)
        return str(fname)

    def schedule_daily(self) -> None:
        def _loop():
            while True:
                time.sleep(86400)
                try: self.generate_html()
                except Exception as e: self.log.error("Report auto : %s", e)
        threading.Thread(target=_loop, daemon=True, name="DailyReport").start()
        self.log.info("Rapport automatique quotidien activé")


