class LLMAnalyzer:
    SEV_ORD = {"LOW":1,"MEDIUM":2,"HIGH":3,"CRITICAL":4}

    def __init__(self, config, yara_sc=None):
        self.enabled = config.get("enabled",False) and REQUESTS_OK
        self.log = logging.getLogger("ARGUS.LLM")
        if not self.enabled: return
        self.endpoint   = config.get("endpoint","")
        self.api_key    = config.get("api_key","")
        self.model      = config.get("model","gpt-4o-mini")
        self.max_tokens = config.get("max_tokens",800)
        self.timeout    = config.get("timeout",30)
        self.template   = config.get("prompt_template","Analyse: {alert_json}")
        self.min_sev    = config.get("min_severity","HIGH")
        self.yara       = yara_sc
        self._q: queue.Queue = queue.Queue(maxsize=config.get("queue_size",100))
        self._res: Dict[str,Dict] = {}; self._lock = threading.Lock()
        threading.Thread(target=self._run, daemon=True, name="LLM").start()
        self.log.info("LLM actif : %s", self.model)

    def _run(self):
        while True:
            a = self._q.get()
            try: self._analyze(a)
            except Exception as e: self.log.error("LLM : %s", e)

    def _analyze(self, alert: Alert):
        safe = {k: getattr(alert,k,None) for k in
                ["type","severity","confidence","mitre_id","mitre_tactic",
                 "kill_chain","detail","source_ip","domain","cve_id",
                 "lgbm_score","bssid","ssid","geo_country","threat_intel"]}
        prompt  = self.template.format(alert_json=json.dumps(safe, indent=2))
        headers = {"Authorization":f"Bearer {self.api_key}","Content-Type":"application/json"}
        body    = {"model":self.model,"messages":[
            {"role":"system","content":"Tu es un analyste cybersécurité SOC/CERT. JSON uniquement."},
            {"role":"user","content":prompt}],
            "max_tokens":self.max_tokens,"temperature":0.1}
        resp = http_req.post(self.endpoint, headers=headers, json=body, timeout=self.timeout)
        if resp.status_code != 200: return
        raw    = resp.json()["choices"][0]["message"]["content"]
        parsed = self._validate(raw)
        if not parsed: return
        alert.llm_analysis = parsed
        inc = (alert.brain or {}).get("incident_id","")
        if inc:
            with self._lock: self._res[inc] = parsed
        if parsed.get("yara_rule") and self.yara:
            self.yara.add_rule(parsed["yara_rule"])

    def _validate(self, raw):
        clean = re.sub(r"```(?:json)?","",raw).strip()
        try: data = json.loads(clean)
        except json.JSONDecodeError: return None
        required = {"explanation","mitigation","risk_score","false_positive_likelihood"}
        if not required.issubset(data): return None
        try: data["risk_score"] = max(1,min(10,int(data["risk_score"])))
        except: data["risk_score"] = 5
        if data["false_positive_likelihood"] not in ("low","medium","high"):
            data["false_positive_likelihood"] = "medium"
        return data

    def submit(self, alert: Alert):
        if not self.enabled: return
        if self.SEV_ORD.get(alert.severity,0) < self.SEV_ORD.get(self.min_sev,3): return
        try: self._q.put_nowait(alert)
        except queue.Full: pass


