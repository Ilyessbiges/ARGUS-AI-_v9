# SECTION 23 — eBPF SENSOR
# ══════════════════════════════════════════════════════════════════════════════

EBPF_PROG = r"""
#include <uapi/linux/ptrace.h>
#include <net/sock.h>
#include <linux/ip.h>
#include <linux/tcp.h>
BPF_HASH(ip_cnt, u32, u64, 65536);
BPF_HASH(port_cnt, u16, u64, 65536);
BPF_PERF_OUTPUT(events);
struct ev_t { u32 src; u32 dst; u16 sport; u16 dport; u8 reason; u32 cnt; };
static inline int rat_port(u16 p) {
    return p==4444||p==1337||p==31337||p==9001||p==9002||p==8443||p==6666||p==55555;
}
int kp(struct pt_regs *ctx, struct sock *sk) {
    struct ev_t e = {};
    u64 *c, one=1, thr=THRESHOLD;
    e.src   = sk->__sk_common.skc_rcv_saddr;
    e.dst   = sk->__sk_common.skc_daddr;
    e.sport = sk->__sk_common.skc_num;
    e.dport = ntohs(sk->__sk_common.skc_dport);
    c = ip_cnt.lookup_or_try_init(&e.src, &one);
    if (c) { (*c)++; e.cnt=*c; if(*c>thr){e.reason=2;events.perf_submit(ctx,&e,sizeof(e));} }
    if (rat_port(e.dport)||rat_port(e.sport)) { e.reason=1; events.perf_submit(ctx,&e,sizeof(e)); }
    return 0;
}
"""

class EBPFSensor:
    def __init__(self, config):
        self.cfg = config; self.enabled = config.get("enabled",False) and EBPF_OK
        self._q: queue.Queue = queue.Queue(maxsize=5000)
        self._bpf = None; self._stop = threading.Event()
        self.log = logging.getLogger("ARGUS.eBPF")

    def start(self):
        if not self.enabled: return False
        try:
            src = EBPF_PROG.replace("THRESHOLD", str(self.cfg.get("drop_threshold",500)))
            self._bpf = BPF(text=src)
            self._bpf.attach_kprobe(event="tcp_v4_rcv", fn_name="kp")
            self._bpf.attach_kprobe(event="udp_rcv",    fn_name="kp")
            self._bpf["events"].open_perf_buffer(self._cb)
            threading.Thread(target=self._poll, daemon=True, name="eBPF").start()
            self.log.info("eBPF actif | seuil=%d pkt/s", self.cfg.get("drop_threshold",500))
            return True
        except Exception as e:
            self.log.error("eBPF init : %s", e)
            self.enabled = False; return False

    def _cb(self, cpu, data, size):
        try:
            e   = self._bpf["events"].event(data)
            src = self._ip(e.src); dst = self._ip(e.dst)
            port = e.dport or e.sport
            if e.reason == 1:
                a = Alert(type="backdoor_behavior",subtype="rat_port_ebpf",
                    severity="HIGH",confidence="high",source_ip=src,dest_ip=dst,
                    port=port,detail=f"[eBPF] Port RAT {port} kernel-space",source="ebpf")
            else:
                a = Alert(type="port_scan",subtype="high_rate_ebpf",
                    severity="MEDIUM",confidence="medium",source_ip=src,dest_ip=dst,
                    port=port,detail=f"[eBPF] Taux élevé : {e.cnt} pkt/s depuis {src}",source="ebpf")
            try: self._q.put_nowait(a)
            except queue.Full: pass
        except Exception: pass

    def _poll(self):
        while not self._stop.is_set():
            try: self._bpf.perf_buffer_poll(timeout=100)
            except Exception: time.sleep(0.1)

    def get_alerts(self):
        out = []
        try:
            while True: out.append(self._q.get_nowait())
        except queue.Empty: pass
        return out

    def stop(self): self._stop.set()

    @staticmethod
    def _ip(n): return f"{n&0xff}.{(n>>8)&0xff}.{(n>>16)&0xff}.{(n>>24)&0xff}"


