class AlertEnricher:
    """Enrichit chaque alerte avec GeoIP, Threat Intel, etc."""
    def __init__(self, geoip: GeoIPResolver, ti: ThreatIntelligence):
        self.geo = geoip
        self.ti  = ti
        self.log = logging.getLogger("ARGUS.Enricher")

    def enrich(self, alert: Alert) -> Alert:
        # GeoIP
        ip = alert.source_ip
        if ip and not FastMath.is_private_ip(ip):
            geo = self.geo.lookup(ip)
            alert.geo_country = geo.get("country","")
            alert.geo_city    = geo.get("city","")
            alert.geo_asn     = geo.get("asn","")
            alert.geo_risk    = geo.get("risk", 0.0)

        # Threat Intel — IP
        if ip:
            is_bad, risk, src = self.ti.check_ip(ip)
            if is_bad:
                alert.threat_intel = True
                alert.ioc_match    = f"ip:{ip} [{src}]"
                alert.severity     = "CRITICAL"
                alert.detail      += f" [IOC:{src}]"
                if alert.type not in ("threat_intel_hit",):
                    alert.type = "threat_intel_hit"

        # Threat Intel — Domain
        if alert.domain:
            is_bad, matched = self.ti.check_domain(alert.domain)
            if is_bad:
                alert.threat_intel = True
                alert.ioc_match    = f"domain:{matched}"
                alert.detail      += f" [IOC-DOMAIN:{matched}]"

        return alert


