class SIEMExporter:
    def __init__(self, path):
        self._path = Path(path); self._path.parent.mkdir(parents=True, exist_ok=True)
        self._lock = threading.Lock()
        self._count = 0
        self.log = logging.getLogger("ARGUS.SIEM")

    def export(self, alert: Alert):
        rec = {"schema_version":"3.0",**alert.to_dict()}
        try:
            with self._lock:
                with open(self._path,"a",encoding="utf-8") as f:
                    f.write(json.dumps(rec)+"\n")
            self._count += 1
        except OSError as e: self.log.error("SIEM : %s",e)

    def export_csv(self, out_path: str = "output/alerts_export.csv") -> str:
        """Exporte toutes les alertes en CSV."""
        if not self._path.exists(): return ""
        rows = []
        for line in self._path.read_text(encoding="utf-8").splitlines():
            try: rows.append(json.loads(line))
            except: pass
        if not rows: return ""
        keys = ["timestamp_iso","type","severity","source_ip","dest_ip",
                "domain","cve_id","mitre_id","action","geo_country","detail"]
        with open(out_path,"w",newline="",encoding="utf-8") as f:
            w = csv.DictWriter(f, fieldnames=keys, extrasaction="ignore")
            w.writeheader(); w.writerows(rows)
        self.log.info("CSV exporté : %s (%d alertes)", out_path, len(rows))
        return out_path

    @property
    def count(self) -> int:
        return self._count


