def create_dashboard(sio, db: DatabaseManager, report_gen: ReportGenerator,
                     pcap_exp: PCAPExporter, ti: ThreatIntelligence) -> Flask:
    app = Flask(__name__)

    @app.route("/")
    def index(): return render_template_string(DASHBOARD_HTML)

    @app.route("/api/alerts")
    def api_alerts():
        n = int(freq.args.get("n",100))
        sev = freq.args.get("severity")
        p   = Path("output/siem_export.jsonl")
        if not p.exists(): return jsonify([])
        lines = p.read_text(encoding="utf-8").strip().split("\n")
        out = []
        for l in lines[-n*3:]:
            try:
                d = json.loads(l)
                if sev and d.get("severity") != sev: continue
                out.append(d)
            except: pass
        return jsonify(out[-n:])

    @app.route("/api/stats")
    def api_stats(): return jsonify(db.recent_stats())

    @app.route("/api/attackers")
    def api_attackers(): return jsonify(db.get_top_attackers())

    @app.route("/api/blocked")
    def api_blocked(): return jsonify(db.get_active_blocks())

    @app.route("/api/ioc/stats")
    def api_ioc_stats(): return jsonify(ti.stats)

    @app.route("/api/pcap/list")
    def api_pcap(): return jsonify(pcap_exp.list_captures())

    @app.route("/api/pcap/download/<filename>")
    def api_pcap_dl(filename):
        fname = Path("output/pcap") / filename
        if fname.exists() and fname.suffix == ".pcap":
            return send_file(str(fname), as_attachment=True)
        return jsonify({"error":"not found"}), 404

    @app.route("/api/report/generate")
    def api_report():
        fname = report_gen.generate_html()
        return jsonify({"file": fname, "status": "generated"})

    @app.route("/api/report/view")
    def api_report_view():
        reports = sorted(Path("output/reports").glob("*.html"), key=lambda f: f.stat().st_mtime, reverse=True)
        if reports:
            return reports[0].read_text(encoding="utf-8")
        return "No report available yet. Call /api/report/generate first.", 404

    @app.route("/api/db/alerts")
    def api_db():
        if not SA_OK: return jsonify({"error":"SQLAlchemy non disponible"})
        sev = freq.args.get("severity"); src = freq.args.get("source")
        lim = int(freq.args.get("limit",100))
        try:
            with db.SessionLocal() as sess:
                q = sess.query(AlertRecord)
                if sev: q = q.filter(AlertRecord.severity==sev)
                if src: q = q.filter(AlertRecord.source==src)
                rows = q.order_by(AlertRecord.timestamp.desc()).limit(lim).all()
                return jsonify([{
                    "incident_id":r.incident_id,"timestamp":r.timestamp,
                    "type":r.type,"severity":r.severity,"source_ip":r.source_ip,
                    "geo_country":r.geo_country,"threat_intel":r.threat_intel,
                    "bssid":r.bssid,"ssid":r.ssid,"risk_score":r.risk_score,
                    "lgbm_score":r.lgbm_score,"action":r.action,
                    "source":r.source,"detail":r.detail,"cve_id":r.cve_id,
                    "mitre_id":r.mitre_id,"kill_chain":r.kill_chain,
                } for r in rows])
        except Exception as e: return jsonify({"error":str(e)})

    @app.route("/api/ioc/add", methods=["POST"])
    def api_ioc_add():
        data = freq.get_json() or {}
        ioc_type = data.get("type","ip"); value = data.get("value","")
        if not value: return jsonify({"error":"value required"}), 400
        ti.add_ioc(ioc_type, value, source="api_manual")
        return jsonify({"status":"added","type":ioc_type,"value":value})

    @app.route("/api/export/csv")
    def api_csv():
        siem = SIEMExporter("output/siem_export.jsonl")
        path = siem.export_csv()
        if path and Path(path).exists():
            return send_file(path, as_attachment=True, download_name="argus_alerts.csv")
        return jsonify({"error":"no data"}), 404

    return app


