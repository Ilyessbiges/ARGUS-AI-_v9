  var wf_b=isWifi?'<span class="badge wifi">802.11</span>':'';
  var llm_b=a.llm_analysis?'<span class="badge llm">LLM✓</span>':'';
  var ti_b=a.threat_intel?'<span class="badge ti">⚠IOC</span>':'';
  var geo_b=a.geo_country?'<span class="badge geo">'+a.geo_country+'</span>':'';
