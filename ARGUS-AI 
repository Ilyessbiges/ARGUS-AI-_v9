class GeoIPResolver:
    HIGH_RISK = frozenset({"CN","RU","KP","IR","SY","CU","SD","MM","BY","VE","AF"})
    MEDIUM_RISK = frozenset({"NG","UA","RO","BR","IN","PK","BD","LY","YE","SO"})

    def __init__(self, db_path: str = "data/GeoLite2-City.mmdb"):
        self.log    = logging.getLogger("ARGUS.GeoIP")
        self._db    = None
        self._cache: Dict[str, Dict] = {}
        if GEOIP_OK and Path(db_path).exists():
            try:
                self._db = geoip2.database.Reader(db_path)
                self.log.info("GeoIP DB chargée : %s", db_path)
            except Exception as e:
                self.log.warning("GeoIP : %s", e)
        else:
            self.log.info("GeoIP non disponible (installez geoip2 + GeoLite2-City.mmdb)")

    def lookup(self, ip: str) -> Dict:
        if not ip or FastMath.is_private_ip(ip):
            return {"country":"LOCAL","city":"","asn":"","risk":0.0}
        if ip in self._cache:
            return self._cache[ip]
        result = {"country":"","city":"","asn":"","risk":0.0}
        if self._db:
            try:
                r = self._db.city(ip)
                c = r.country.iso_code or ""
                result["country"] = c
                result["city"]    = r.city.name or ""
                result["risk"]    = (1.0 if c in self.HIGH_RISK else
                                     0.5 if c in self.MEDIUM_RISK else 0.1)
            except Exception:
                pass
        self._cache[ip] = result
        if len(self._cache) > 50000:
            # LRU simple : supprimer la moitié
            keys = list(self._cache.keys())
            for k in keys[:25000]:
                del self._cache[k]
        return result

    def risk_score(self, ip: str) -> float:
        return self.lookup(ip).get("risk", 0.0)


