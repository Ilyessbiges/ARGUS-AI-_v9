# SECTION 12 — DNS TUNNELING DETECTOR
# ══════════════════════════════════════════════════════════════════════════════

class DNSTunnelingDetector:
    """
    Détecte la tunnelisation DNS (ex: iodine, dns2tcp, dnscat2) via :
    - Longueur anormale des labels (>45 chars)
    - Haute entropie des requêtes
    - Taux de requêtes élevé vers même domaine racine
    - Requêtes TXT/NULL excessives
    - Ratio requêtes/réponses anormal
    - Noms encodés (base32, base64 dans label)
    """
    def __init__(self, config: Dict):
        cfg             = config.get("dns_tunnel", {})
        self.enabled    = cfg.get("enabled", True)
        self.label_min  = cfg.get("label_len_min", 45)
        self.ent_min    = cfg.get("entropy_min", 3.8)
        self.rate_max   = cfg.get("query_rate_max", 20)
        self.win        = cfg.get("time_window", 10)
        self.txt_sus    = cfg.get("txt_suspicious", True)
        self.log        = logging.getLogger("ARGUS.DNSTunnel")
        self._queries:  Dict[str, deque] = defaultdict(lambda: deque(maxlen=1000))
        self._roots:    Dict[str, Dict[str, deque]] = defaultdict(lambda: defaultdict(lambda: deque(maxlen=500)))
        self._txt_cnt:  Dict[str, deque] = defaultdict(lambda: deque(maxlen=500))

    def _extract_root(self, domain: str) -> str:
        """Extrait le domaine racine (2ème niveau)."""
        parts = domain.rstrip(".").split(".")
        return ".".join(parts[-2:]) if len(parts) >= 2 else domain

    def analyze(self, pkt) -> List[Alert]:
        if not (self.enabled and SCAPY_OK): return []
        if not (pkt.haslayer(IP) and pkt.haslayer(DNS)): return []
        dns = pkt[DNS]; src = pkt[IP].src
        if not dns.qr == 0: return []  # Requêtes seulement
        alerts: List[Alert] = []
        now = time.time()

        if not pkt.haslayer(DNSQR): return []
        try:
            qname  = pkt[DNSQR].qname.decode(errors="replace").rstrip(".")
            qtype  = pkt[DNSQR].qtype
        except Exception:
            return []

        self._queries[src].append(now)

        # Taux de requêtes
        rate = FastMath.sliding_rate(self._queries[src], self.win)
        if rate > self.rate_max:
            alerts.append(Alert(
                type="dns_tunnel", subtype="high_rate",
                severity="HIGH", confidence="medium",
                source_ip=src, domain=qname,
                detail=f"Taux DNS anormal : {rate} requêtes/{self.win}s depuis {src}",
            ))

        # Label trop long ou haute entropie
        labels = qname.split(".")
        for label in labels[:-2]:  # Ignorer le TLD et domaine racine
            if len(label) >= self.label_min:
                ent = FastMath.entropy_str(label)
                if ent >= self.ent_min:
                    alerts.append(Alert(
                        type="dns_tunnel", subtype="long_label",
                        severity="CRITICAL", confidence="high",
                        source_ip=src, domain=qname,
                        entropy=round(ent, 3),
                        dns_query_len=len(label),
                        detail=f"DNS Tunneling ! Label={len(label)}chars ent={ent:.2f} '{label[:40]}'",
                    ))
                    break

        # Requêtes TXT suspectes
        if self.txt_sus and qtype == 16:  # TXT record
            root = self._extract_root(qname)
            self._txt_cnt[root].append(now)
            txt_rate = FastMath.sliding_rate(self._txt_cnt[root], 60)
            if txt_rate > 10:
                alerts.append(Alert(
                    type="dns_tunnel", subtype="txt_flood",
                    severity="HIGH", confidence="medium",
                    source_ip=src, domain=qname,
                    dns_type="TXT",
                    detail=f"Flood requêtes DNS TXT : {txt_rate}/min vers {root}",
                ))

        # Même root domain, trop de sous-domaines distincts
        root = self._extract_root(qname)
        self._roots[src][root].append((now, qname))
        distinct = len(set(q for t,q in self._roots[src][root] if now-t <= 60))
        if distinct > 30:
            alerts.append(Alert(
                type="dns_tunnel", subtype="many_subdomains",
                severity="HIGH", confidence="medium",
                source_ip=src, domain=root,
                detail=f"Tunneling DNS : {distinct} sous-domaines distincts de {root} en 60s",
            ))

        return alerts


