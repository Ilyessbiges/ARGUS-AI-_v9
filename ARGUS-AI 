# SECTION 21 — ARGUS BRAIN v3
# ══════════════════════════════════════════════════════════════════════════════

class ARGUSBrain:
    SEV_W = {"CRITICAL":10,"HIGH":7,"MEDIUM":4,"LOW":1}

    def __init__(self, config, mitre, lgbm, db):
        self.mitre    = mitre; self.lgbm = lgbm; self.db = db
        self.learning = config.get("interfaces",{}).get("learning_mode", False)
        self.memory:  Dict[str, deque] = defaultdict(lambda: deque(maxlen=500))
        self._chain:  Dict[str, List]  = defaultdict(list)   # kill chain tracking
        self.log = logging.getLogger("ARGUS.Brain")

    def process(self, alert: Alert) -> Dict:
        src = alert.source_ip or alert.bssid or alert.domain or "?"
        self.memory[src].append((time.time(), alert.severity, alert.type))
        m = self.mitre.map(alert.type)
        alert.mitre_id    = m["id"]
        alert.mitre_tactic = m["tactic"]
        alert.kill_chain  = m.get("kill_chain", "unknown")

        # Kill chain tracking
        self._chain[src].append(alert.kill_chain)
        chain_stages = set(self._chain[src][-10:])

        # Multi-signal correlation
        recent = sum(1 for ts,_,_ in self.memory[src] if time.time()-ts<300)
        recent_types = {t for ts,_,t in self.memory[src] if time.time()-ts<300}

        # Escalade si progression dans kill chain
        if len(chain_stages) >= 3:
            alert.severity = "CRITICAL"
            alert.detail  += f" [KILL-CHAIN:{'>'.join(list(chain_stages)[:3])}]"
        elif recent >= 3:
            alert.severity = "CRITICAL"
            alert.detail  += " [CORRÉLATION MULTI-SIGNAL]"

        if self.lgbm:
            prob   = self.lgbm.score(alert)
            alert.lgbm_score = round(prob, 4)
            risk   = round(prob*10, 2)
            action = self.lgbm.action_from_score(prob)
        else:
            base   = self.SEV_W.get(alert.severity,1)
            bonus  = min(recent/5, 1.0)*0.3 + alert.geo_risk*0.2 + (0.3 if alert.threat_intel else 0.0)
            risk   = min(round(base*(1+bonus), 2), 10.0)
            s      = risk/10.0
            action = ("ISOLATE" if s>=0.90 else "BLOCK_IP" if s>=0.75
                      else "ALERT" if s>=0.55 else "MONITOR")

        result = {
            "incident_id":        self.db.next_incident_id(),
            "risk_score":         risk,
            "recommended_action": action,
            "escalate":           alert.severity == "CRITICAL",
            "correlated_alerts":  recent,
            "distinct_types":     len(recent_types),
            "kill_chain_stages":  len(chain_stages),
            "scored_by":          "lgbm" if (self.lgbm and self.lgbm.model) else "heuristic",
            "threat_intel":       alert.threat_intel,
            "geo_risk":           round(alert.geo_risk, 2),
        }
        alert.brain = result
        return result


