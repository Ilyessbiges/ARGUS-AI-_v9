class ARGUSPipelineV9:
    def __init__(self, config: Dict, iface_mgr: KaliInterfaceManager, socketio_=None):
        self.config     = config
        self.iface      = iface_mgr
        self.auto_block = config.get("interfaces",{}).get("auto_block", False)
        self.learning   = config.get("interfaces",{}).get("learning_mode", False)
        self.sio        = socketio_
        self._stop      = threading.Event()

        # Infrastructure
        self.db   = DatabaseManager(config)
        self.siem = SIEMExporter(config.get("siem_file","output/siem_export.jsonl"))
        self.pcap = PCAPExporter(config)

        # Intelligence
        self.mitre  = MitreMapper()
        self.geoip  = GeoIPResolver(config.get("geoip_db","data/GeoLite2-City.mmdb"))
        self.ti     = ThreatIntelligence(config, self.db)
        self.enrich = AlertEnricher(self.geoip, self.ti)

        # Détecteurs réseau
        self.dns      = DNSBeaconDetector(config)
        self.tls      = TLSAnalyzer()
        self.dga      = DGADetector(config.get("model_path","models/dga_model.pkl"))
        self.yara     = YaraScanner(config.get("yara_rules","rules/yara_rules.yar"))
        self.bof      = BufferOverflowDetector(config)
        self.backdoor = BackdoorDetector()
        self.cve      = CVEMatcher()
        self.wifi_det = WiFiDetector(config)

        # Nouveaux détecteurs
        self.port_scan  = PortScanDetector(config)
        self.ssh_bf     = SSHBruteForceDetector(config)
        self.http_anom  = HTTPAnomalyDetector(config)
        self.dns_tunnel = DNSTunnelingDetector(config)
        self.lateral    = LateralMovementDetector(config)
        self.data_exfil = DataExfiltrationDetector(config)

        # ML
        self.lgbm  = LGBMCorrelationModel(config.get("lgbm",{}), self.db)
        self.brain = ARGUSBrain(config, self.mitre, self.lgbm, self.db)

        # Response
        self.llm      = LLMAnalyzer(config.get("llm",{}), self.yara)
        self.rl       = RLResponseAgent(config.get("rl_agent",{}))
        self.playbook = IncidentPlaybook(config, iface_mgr, self.db, self.ti)

        # Reporting
        self.report = ReportGenerator(config, self.db)
        self.report.schedule_daily()

        # Sources externes
        self.zeek: Optional[ZeekConsumer] = None
        if config.get("zeek",{}).get("enabled",False):
            self.zeek = ZeekConsumer(config["zeek"], self.dns, self.dga, self.tls)
            self.zeek.start()

        self.ebpf: Optional[EBPFSensor] = None
        if config.get("ebpf",{}).get("enabled",False):
            self.ebpf = EBPFSensor(config["ebpf"])
            if not self.ebpf.start(): self.ebpf = None

        # Channel hopping Wi-Fi
        self.hopper: Optional[ChannelHopper] = None
        if (config.get("wifi",{}).get("channel_hop",True)
                and config.get("interfaces",{}).get("monitor_mode",False)):
            self.hopper = ChannelHopper(config, iface_mgr)
            self.hopper.start()

        # Bus événements
        self._bus: queue.Queue = queue.Queue(maxsize=20000)
        threading.Thread(target=self._dispatch_loop, daemon=True, name="Dispatcher").start()
        threading.Thread(target=self._poll_sensors,  daemon=True, name="SensorPoll").start()
        if self.rl.enabled:
            threading.Thread(target=self._rl_loop, daemon=True, name="RL-Reward").start()
        if self.sio:
            threading.Thread(target=self._broadcast_loop, daemon=True, name="Broadcast").start()

        if self.sio:
            self.sio.emit("modules",{
                "llm":  self.llm.enabled,    "rl":   self.rl.enabled,
                "lgbm": self.lgbm.enabled,   "zeek": self.zeek is not None,
                "ebpf": self.ebpf is not None,"cext": CEXT_OK,
                "wifi": True,                 "ti":   self.ti.enabled,
                "geo":  self.geoip._db is not None,
            })

        self.pkt_count = 0; self.alert_count = 0
        self.blocked: Set[str] = set(); self.start_time = datetime.now()
        self.log = logging.getLogger("ARGUS.Pipeline")
        self.log.info(
            "Pipeline v9.0 prêt | wlan0=%s wlan1=%s LGBM=%s RL=%s TI=%s GeoIP=%s",
            iface_mgr.wlan0, iface_mgr.wlan1,
            self.lgbm.enabled, self.rl.enabled,
            self.ti.enabled, self.geoip._db is not None,
        )

    # ── Bus ──────────────────────────────────────────────────────────────

    def _enqueue(self, alerts):
        if alerts:
            try: self._bus.put_nowait(alerts)
            except queue.Full: self.log.warning("Bus saturé — %d alertes perdues", len(alerts))

    def _dispatch_loop(self):
        while not self._stop.is_set():
            try: self._dispatch(self._bus.get(timeout=0.5))
            except queue.Empty: continue

    # ── Capteur wlan0 (IP/TCP/UDP) ────────────────────────────────────────

    def process_packet(self, pkt):
        self.pkt_count += 1
        alerts = []

        # Détecteurs classiques
        alerts.extend(self.bof.analyze(pkt))
        alerts.extend(self.backdoor.analyze(pkt))
        alerts.extend(self.cve.analyze(pkt))

        # Nouveaux détecteurs
        alerts.extend(self.port_scan.analyze(pkt))
        alerts.extend(self.ssh_bf.analyze(pkt))
        alerts.extend(self.http_anom.analyze(pkt))
        alerts.extend(self.data_exfil.analyze(pkt))
        if SCAPY_OK and pkt.haslayer(IP):
            alerts.extend(self.lateral.analyze(pkt))

        # DNS (scapy)
        if SCAPY_OK and pkt.haslayer(DNS):
            alerts.extend(self.dns_tunnel.analyze(pkt))
        if SCAPY_OK and pkt.haslayer(DNSQR):
            dom = pkt[DNSQR].qname.decode(errors="replace").rstrip(".")
            for fn in (self.dns.analyze, self.dga.analyze):
                a = fn(dom)
                if a: a.source="wlan0"; alerts.append(a)

        # TLS JA3
        ja3 = self.tls.compute_ja3(pkt)
        if ja3:
            a = self.tls.analyze(hashlib.md5(ja3.encode()).hexdigest())
            if a: a.source="wlan0"; alerts.append(a)

        # YARA
        if SCAPY_OK and pkt.haslayer(Raw) and YARA_OK:
            m = self.yara.scan(bytes(pkt[Raw].load))
            if m:
                src = pkt[IP].src if pkt.haslayer(IP) else "?"
                alerts.append(Alert(type="yara_match",severity="CRITICAL",confidence="high",
                    source_ip=src,yara_rules=m,source="wlan0",
                    detail=f"YARA match : {', '.join(m)}"))

        # ARP
        if SCAPY_OK and pkt.haslayer(ARP):
            alerts.extend(self.wifi_det._check_arp(pkt))

        for a in alerts: a.source = a.source or "wlan0"
        self._enqueue(alerts)

        # PCAP pour paquets suspects
        if alerts and self.pcap.enabled:
            for a in alerts:
                if a.severity in ("CRITICAL","HIGH"):
                    self.pcap.capture(pkt, a)
                    break

        if self.pkt_count % 10000 == 0: self._print_stats()

    # ── Capteur wlan1mon (802.11) ─────────────────────────────────────────

    def process_wifi_packet(self, pkt):
        alerts = self.wifi_det.analyze(pkt)
        for a in alerts: a.source = "wlan1"
        self._enqueue(alerts)
        if alerts and self.pcap.enabled:
            for a in alerts:
                if a.severity == "CRITICAL":
                    self.pcap.capture(pkt, a); break

    # ── Synthétique ───────────────────────────────────────────────────────

    def process_synthetic(self, domain, fp, src_ip=None):
        alerts = []
        for fn in (self.dns.analyze, self.dga.analyze):
            a = fn(domain)
            if a: a.source_ip=src_ip; a.source="simulator"; alerts.append(a)
        a = self.tls.analyze(fp)
        if a: a.source_ip=src_ip; a.source="simulator"; alerts.append(a)
        self._enqueue(alerts)

    # ── Dispatch ──────────────────────────────────────────────────────────

    def _dispatch(self, alerts):
        # Multi-signal correlation
        if len(alerts) >= 2:
            for a in alerts:
                a.severity = "CRITICAL"
                a.detail  += " [MULTI-SIGNAL]"

        for alert in alerts:
            alert.timestamp = time.time()
            self.alert_count += 1

            # 1. Enrichissement
            alert = self.enrich.enrich(alert)

            # 2. Brain (MITRE + LGBM + corrélation)
            if not self.learning:
                self.brain.process(alert)

            # 3. RL Agent
            if self.rl.enabled and (alert.source_ip or alert.bssid):
                key = alert.source_ip or alert.bssid
                self.rl.record_repeat(key, alert.type)

            if self.rl.enabled and not self.learning:
                action = self.rl.select_action(alert)
                alert.action = action
                ip = alert.source_ip
                if action in ("block","isolate") and self.auto_block and ip:
                    if ip not in self.blocked:
                        self.iface.block_ip(ip, f"RL:{alert.type}")
                        self.db.add_blocked_ip(ip, f"RL-{action}:{alert.type}", expires_h=24)
                        self.blocked.add(ip)
                    alert.detail += f" [RL-{action.upper()}]"
                elif action == "honeypot" and ip:
                    self.iface.add_honeypot_rule(ip)
                elif action == "throttle" and ip:
                    self.iface.throttle_ip(ip)
            else:
                if self.auto_block and not self.learning and alert.brain:
                    rec = alert.brain.get("recommended_action","")
                    if rec in ("BLOCK_IP","ISOLATE"):
                        ip = alert.source_ip
                        if ip and ip not in self.blocked:
                            self.iface.block_ip(ip, f"Brain:{alert.type}")
                            self.blocked.add(ip)

            # 4. Playbook
            if not self.learning and alert.severity in ("CRITICAL","HIGH"):
                self.playbook.execute(alert, self.iface)

            # 5. LLM
            if self.llm.enabled: self.llm.submit(alert)

            # 6. Persistance
            inc = (alert.brain or {}).get("incident_id") or self.db.next_incident_id()
            self.db.insert_alert(alert, inc)
            self.siem.export(alert)

            # 7. Dashboard
            if self.sio: self.sio.emit("new_alert", alert.to_dict())

            # 8. Console
            self._print_alert(alert)

    # ── Polling capteurs externes ─────────────────────────────────────────

    def _poll_sensors(self):
        while not self._stop.is_set():
            alerts = []
            if self.zeek: alerts.extend(self.zeek.get_alerts())
            if self.ebpf: alerts.extend(self.ebpf.get_alerts())
            if alerts: self._enqueue(alerts)
            time.sleep(0.1)

    def _rl_loop(self):
        while not self._stop.is_set():
            self.rl.evaluate_pending(); time.sleep(15)

    def _broadcast_loop(self):
        while not self._stop.is_set():
            if self.rl.enabled: self.sio.emit("rl_status", self.rl.status)
            avail = self.iface.check_interfaces()
            self.sio.emit("iface_status",{
                "wlan0":    avail.get(self.iface.wlan0, False),
                "wlan1":    avail.get(self.iface.wlan1, False),
                "mon_if":   self.iface.mon_if,
                "channel":  self.hopper.current_channel if self.hopper else None,
                "db_total": self.alert_count,
                "ioc_stats":self.ti.stats,
            })
            self.sio.emit("modules",{
                "llm":self.llm.enabled,"rl":self.rl.enabled,"lgbm":self.lgbm.enabled,
                "zeek":self.zeek is not None,"ebpf":self.ebpf is not None,
                "cext":CEXT_OK,"wifi":True,"ti":self.ti.enabled,
                "geo":self.geoip._db is not None,
            })
            time.sleep(4)

    # ── Console ───────────────────────────────────────────────────────────

    def _print_alert(self, alert: Alert):
        C = {"CRITICAL":"\033[91m","HIGH":"\033[93m","MEDIUM":"\033[94m","LOW":"\033[92m"}
        c = C.get(alert.severity,"\033[0m"); R = "\033[0m"
        ts = datetime.fromtimestamp(alert.timestamp).strftime("%H:%M:%S")
        geo_info  = f" [{alert.geo_country}]" if alert.geo_country else ""
        ti_info   = " ⚠IOC" if alert.threat_intel else ""
        lg_info   = f" LGBM={alert.lgbm_score:.3f}" if alert.lgbm_score is not None else ""
        kc_info   = f" KC={alert.kill_chain}" if alert.kill_chain != "unknown" else ""
        wifi_info = ""
        if alert.ssid:
            wifi_info = f"\n  📶 SSID={alert.ssid} BSSID={alert.bssid} CH={alert.channel}"
        http_info = ""
        if alert.http_uri:
            http_info = f"\n  🌐 {alert.http_method} {str(alert.http_uri)[:80]}"
        print(
            f"\n{c}╔{'═'*84}╗\n"
            f"  🚨 [{alert.severity:8s}] {alert.type.upper():<26s} [{alert.source.upper():<9s}] {alert.mitre_id}{kc_info}\n"
            f"  📍 src={str(alert.source_ip or alert.mac_src or alert.domain or '?'):<22s}"
            f"conf={alert.confidence:<7s} ts={ts}{geo_info}{ti_info}{lg_info}\n"
            f"  💬 {str(alert.detail)[:120]}"
            + wifi_info + http_info
            + (f"\n  🤖 RL→{alert.action.upper()}" if alert.action!="allow" else "")
            + (f"\n  🧠 {alert.brain['incident_id']} | {alert.brain['recommended_action']}"
               f" | {alert.brain['risk_score']}/10 [{alert.brain['scored_by']}]"
               + (" ⚠ESCALADE" if alert.brain.get("escalate") else "")
               if alert.brain else "")
            + f"\n╚{'═'*84}╝{R}"
        )

    def _print_stats(self):
        up = datetime.now() - self.start_time
        self.log.info(
            "Stats | uptime=%s pkts=%d alertes=%d bloqués=%d | IOC:%s",
            str(up).split(".")[0], self.pkt_count, self.alert_count,
            len(self.blocked), str(self.ti.stats)
        )

    # ── Sniffing ──────────────────────────────────────────────────────────

    def start_sniffing_wlan0(self):
        if not SCAPY_OK: self.log.error("Scapy manquant."); return
        self.log.info("Sniffing wlan0 : %s", self.iface.wlan0)
        try:
            sniff(iface=self.iface.wlan0, prn=self.process_packet,
                  store=False, filter="ip or arp")
        except PermissionError: self.log.error("Permission refusée — lancez avec sudo")
        except KeyboardInterrupt: pass
        finally: self._print_stats()

    def start_sniffing_wlan1(self):
        if not SCAPY_OK: return
        mon = self.iface.mon_if
        self.log.info("Sniffing 802.11 : %s", mon)
        try:
            sniff(iface=mon, prn=self.process_wifi_packet, store=False)
        except PermissionError: self.log.error("Permission refusée sur %s", mon)
        except KeyboardInterrupt: pass

    def shutdown(self):
        self._stop.set()
        if self.zeek:  self.zeek.stop()
        if self.ebpf:  self.ebpf.stop()
        if self.hopper:self.hopper.stop()
        self.iface.disable_monitor_mode()
        self.log.info("Pipeline arrêté proprement.")


