# SECTION 10 — SSH BRUTE FORCE DETECTOR
# ══════════════════════════════════════════════════════════════════════════════

class SSHBruteForceDetector:
    """
    Détecte les attaques brute-force SSH via :
    - Comptage des connexions TCP/22 par IP source
    - Analyse des banners SSH (version fingerprinting)
    - Détection des patterns Hydra/Medusa/Metasploit
    """
    SSH_TOOLS_PATTERNS = [
        b"SSH-2.0-libssh",
        b"SSH-2.0-JSCH",
        b"SSH-2.0-paramiko",
        b"SSH-2.0-Go",
        b"SSH-2.0-OpenSSH_for_Windows",
    ]
    KALI_TOOLS = [b"Hydra", b"Medusa", b"ncrack", b"patator"]

    def __init__(self, config: Dict):
        cfg              = config.get("ssh_bruteforce", {})
        self.enabled     = cfg.get("enabled", True)
        self.thresh      = cfg.get("fail_threshold", 5)
        self.win         = cfg.get("time_window", 60)
        self.log         = logging.getLogger("ARGUS.SSH")
        self._attempts:  Dict[str, deque] = defaultdict(lambda: deque(maxlen=500))
        self._success:   Dict[str, deque] = defaultdict(lambda: deque(maxlen=100))
        self._banners:   Dict[str, str]   = {}

    def analyze(self, pkt) -> List[Alert]:
        if not (self.enabled and SCAPY_OK): return []
        if not (pkt.haslayer(IP) and pkt.haslayer(TCP)): return []
        alerts: List[Alert] = []
        tcp = pkt[TCP]; src = pkt[IP].src; dst = pkt[IP].dst
        now = time.time()

        # Port 22 connexions entrantes
        if tcp.dport == 22 and tcp.flags & 0x02:
            self._attempts[src].append(now)
            count = FastMath.sliding_rate(self._attempts[src], self.win)
            if count >= self.thresh:
                alerts.append(Alert(
                    type="ssh_bruteforce", severity="HIGH", confidence="high",
                    source_ip=src, dest_ip=dst, port=22,
                    detail=f"SSH brute-force : {count} tentatives en {self.win}s depuis {src}",
                ))

        # Analyse du banner SSH
        if pkt.haslayer(Raw) and (tcp.dport == 22 or tcp.sport == 22):
            payload = bytes(pkt[Raw].load)
            if payload.startswith(b"SSH-"):
                banner = payload[:64].decode(errors="replace").strip()
                self._banners[src] = banner
                for pat in self.SSH_TOOLS_PATTERNS:
                    if pat in payload:
                        alerts.append(Alert(
                            type="ssh_bruteforce", subtype="tool_fingerprint",
                            severity="MEDIUM", confidence="medium",
                            source_ip=src, dest_ip=dst, port=22,
                            detail=f"Tool SSH détecté : {banner[:60]}",
                        ))
                        break
                for pat in self.KALI_TOOLS:
                    if pat.lower() in payload.lower():
                        alerts.append(Alert(
                            type="ssh_bruteforce", subtype="kali_tool",
                            severity="CRITICAL", confidence="high",
                            source_ip=src, dest_ip=dst, port=22,
                            detail=f"Outil de crack SSH Kali détecté : {pat.decode()}",
                        ))

        return alerts


