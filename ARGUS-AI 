class ThreatIntelligence:
    """
    Gestion des IOC (Indicators of Compromise) :
    - IPs malveillantes (feeds externes + fichier local)
    - Domaines C2 connus
    - Hash de fichiers malveillants
    - Mise à jour automatique des feeds
    """
    HIGH_RISK_COUNTRIES = frozenset({
        "CN","RU","KP","IR","SY","CU","SD","MM","BY","VE"
    })
    MEDIUM_RISK_COUNTRIES = frozenset({
        "NG","UA","RO","BR","IN","PK","BD"
    })

    def __init__(self, config: Dict, db: "DatabaseManager"):
        self.cfg        = config.get("threat_intel", {})
        self.db         = db
        self.enabled    = self.cfg.get("enabled", True)
        self.log        = logging.getLogger("ARGUS.ThreatIntel")
        self._bad_ips:  Set[str] = set()
        self._bad_doms: Set[str] = set()
        self._bad_hash: Set[str] = set()
        self._lock      = threading.Lock()
        self._load_local()
        if self.enabled:
            threading.Thread(target=self._auto_refresh,
                             daemon=True, name="TI-Refresh").start()

    def _load_local(self) -> None:
        f = Path(self.cfg.get("local_ioc_file","data/ioc_list.txt"))
        if not f.exists():
            f.parent.mkdir(parents=True, exist_ok=True)
            f.write_text("# ARGUS IOC List — format: type:value\n# ip:1.2.3.4\n# domain:evil.com\n# hash:abc123\n")
            return
        count = 0
        for line in f.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#"): continue
            if ":" in line:
                t, v = line.split(":", 1)
                v = v.strip().lower()
                if t == "ip":     self._bad_ips.add(v); count+=1
                elif t == "domain": self._bad_doms.add(v); count+=1
                elif t == "hash": self._bad_hash.add(v); count+=1
            else:
                # Assume IP si format valide
                try:
                    ipaddress.ip_address(line); self._bad_ips.add(line); count+=1
                except ValueError:
                    self._bad_doms.add(line.lower()); count+=1
        self.log.info("IOC locaux : %d entrées (%d IP, %d domaines, %d hash)",
                      count, len(self._bad_ips), len(self._bad_doms), len(self._bad_hash))

    def _fetch_feed(self, url: str) -> Set[str]:
        if not REQUESTS_OK: return set()
        ips: Set[str] = set()
        try:
            r = http_req.get(url, timeout=15, headers={"User-Agent":"ARGUS-IDS/9.0"})
            if r.status_code != 200: return ips
            for line in r.text.splitlines():
                line = line.strip()
                if not line or line.startswith("#"): continue
                try:
                    ipaddress.ip_address(line); ips.add(line)
                except ValueError:
                    pass
            self.log.info("Feed '%s' : %d IPs", url[:60], len(ips))
        except Exception as e:
            self.log.warning("Feed %s : %s", url[:60], e)
        return ips

    def _auto_refresh(self) -> None:
        interval = self.cfg.get("refresh_hours", 6) * 3600
        while True:
            time.sleep(60)  # Premier refresh après 1 min
            feeds = self.cfg.get("feeds", [])
            new_ips: Set[str] = set()
            for url in feeds:
                new_ips |= self._fetch_feed(url)
            if new_ips:
                with self._lock:
                    self._bad_ips |= new_ips
                self.log.info("ThreatIntel mis à jour : +%d IPs", len(new_ips))
            time.sleep(interval - 60)

    def check_ip(self, ip: str) -> Tuple[bool, float, str]:
        """Retourne (is_malicious, geo_risk_score, source)"""
        if not ip: return False, 0.0, ""
        with self._lock:
            if ip in self._bad_ips:
                return True, 1.0, "ioc_feed"
        # GeoIP risk
        return False, 0.0, ""

    def check_domain(self, domain: str) -> Tuple[bool, str]:
        if not domain: return False, ""
        dom_lower = domain.lower()
        with self._lock:
            for bad in self._bad_doms:
                if dom_lower == bad or dom_lower.endswith("." + bad):
                    return True, bad
        return False, ""

    def check_hash(self, h: str) -> bool:
        with self._lock:
            return h.lower() in self._bad_hash

    def add_ioc(self, ioc_type: str, value: str, source: str = "manual") -> None:
        v = value.lower()
        with self._lock:
            if ioc_type == "ip":     self._bad_ips.add(v)
            elif ioc_type == "domain": self._bad_doms.add(v)
            elif ioc_type == "hash": self._bad_hash.add(v)
        if SA_OK and self.db.SessionLocal:
            try:
                with self.db._lock:
                    with self.db.SessionLocal() as sess:
                        existing = sess.query(ThreatIOC).filter_by(value=v).first()
                        if not existing:
                            sess.add(ThreatIOC(ioc_type=ioc_type, value=v, source=source))
                            sess.commit()
            except Exception:
                pass

    @property
    def stats(self) -> Dict:
        with self._lock:
            return {"bad_ips":len(self._bad_ips),"bad_domains":len(self._bad_doms),
                    "bad_hashes":len(self._bad_hash)}


