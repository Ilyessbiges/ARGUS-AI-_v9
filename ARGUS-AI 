class FastMath:
    @staticmethod
    def entropy_bytes(data: bytes) -> float:
        if CEXT_OK: return _cext.c_entropy_bytes(data)
        if not data: return 0.0
        return -sum(p * math.log2(p) for p in
                    [data.count(b)/len(data) for b in set(data)] if p > 0)

    @staticmethod
    def entropy_str(s: str) -> float:
        if CEXT_OK: return _cext.c_entropy_str(s)
        if not s: return 0.0
        return -sum(p * math.log2(p) for p in
                    [s.count(c)/len(s) for c in set(s)] if p > 0)

    @staticmethod
    def consonant_ratio(s: str) -> float:
        if CEXT_OK: return _cext.c_consonant_ratio(s)
        alpha = [c for c in s.lower() if c.isalpha()]
        return sum(1 for c in alpha if c not in "aeiou") / len(alpha) if alpha else 0.0

    @staticmethod
    def nop_sled(data: bytes, n: int = 16) -> bool:
        if CEXT_OK: return bool(_cext.c_nop_sled(data, n))
        count = 0
        for b in data:
            count = count + 1 if b == 0x90 else 0
            if count >= n: return True
        return False

    @staticmethod
    def parse_ja3(payload: bytes) -> Tuple:
        if CEXT_OK: return _cext.c_parse_ja3_fields(payload)
        try:
            if len(payload) < 5 or payload[0] != 0x16: return None, None, None
            ver = struct.unpack(">H", payload[1:3])[0]
            off = 43
            if off >= len(payload): return None, None, None
            sl = payload[off]; off += 1 + sl
            if off + 2 > len(payload): return None, None, None
            cl = struct.unpack(">H", payload[off:off+2])[0]; off += 2
            ciphers = [str(struct.unpack(">H", payload[off+i:off+i+2])[0])
                       for i in range(0, cl, 2) if off+i+2 <= len(payload)]
            off += cl
            if off < len(payload): off += 1 + payload[off]
            exts = []
            if off + 2 <= len(payload):
                et = struct.unpack(">H", payload[off:off+2])[0]; off += 2; end = off + et
                while off + 4 <= end <= len(payload):
                    etype = struct.unpack(">H", payload[off:off+2])[0]
                    elen  = struct.unpack(">H", payload[off+2:off+4])[0]
                    exts.append(str(etype)); off += 4 + elen
            return str(ver), ",".join(ciphers), ",".join(exts)
        except Exception:
            return None, None, None

    @staticmethod
    def is_private_ip(ip: str) -> bool:
        try:
            return ipaddress.ip_address(ip).is_private
        except Exception:
            return False

    @staticmethod
    def ip_in_subnet(ip: str, subnets: List[str]) -> bool:
        try:
            addr = ipaddress.ip_address(ip)
            return any(addr in ipaddress.ip_network(s, strict=False) for s in subnets)
        except Exception:
            return False

    @staticmethod
    def sliding_rate(ts_deque: deque, window_s: float) -> int:
        now = time.time()
        return sum(1 for t in ts_deque if now - t <= window_s)


