class ChannelHopper:
    def __init__(self, config: Dict, iface_mgr: KaliInterfaceManager):
        self.cfg      = config.get("wifi", {})
        self.iface    = iface_mgr
        self.channels = self.cfg.get("channels", list(range(1, 14)))
        self.interval = self.cfg.get("hop_interval", 0.3)
        self._stop    = threading.Event()
        self._current = 0
        self.log      = logging.getLogger("ARGUS.ChanHop")

    def start(self) -> None:
        t = threading.Thread(target=self._hop, daemon=True, name="ChanHopper")
        t.start()
        self.log.info("Channel hopping actif : %d canaux, %.1fs/canal",
                      len(self.channels), self.interval)

    def _hop(self) -> None:
        while not self._stop.is_set():
            ch = self.channels[self._current % len(self.channels)]
            self.iface.set_channel(ch)
            self._current += 1
            time.sleep(self.interval)

    def stop(self) -> None: self._stop.set()

    @property
    def current_channel(self) -> int:
        return self.channels[self._current % len(self.channels)]


