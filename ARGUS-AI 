class DataExfiltrationDetector:
    """
    Détecte l'exfiltration de données :
    - Gros volume sortant vers même destination
    - Données encodées (base64, compression) dans le payload
    - Staging (envoi groupé vers serveur externe)
    - Fréquence/rythme d'envoi suspect
    - Ports non-standards avec gros volumes
    """
    def __init__(self, config: Dict):
        cfg                  = config.get("data_exfil", {})
        self.enabled         = cfg.get("enabled", True)
        self.limit_bytes     = cfg.get("outbound_limit_mb", 50) * 1024 * 1024
        self.win             = cfg.get("time_window", 300)
        self.comp_detect     = cfg.get("compression_detect", True)
        self.b64_detect      = cfg.get("b64_detect", True)
        self.staging         = cfg.get("staging_detect", True)
        self.sus_ports       = frozenset(cfg.get("suspicious_ports",
                                [6666,7777,8888,9999,31337,4444,55555]))
        self.log             = logging.getLogger("ARGUS.DataExfil")
        self._bytes_out:     Dict[str, Dict[str, List]] = defaultdict(lambda: defaultdict(list))
        # {src: {dst: [(timestamp, bytes)]}}

    def analyze(self, pkt) -> List[Alert]:
        if not (self.enabled and SCAPY_OK): return []
        if not (pkt.haslayer(IP) and pkt.haslayer(Raw)): return []
        alerts: List[Alert] = []
        src = pkt[IP].src; dst = pkt[IP].dst
        pl  = bytes(pkt[Raw].load); now = time.time()
        dport = pkt[TCP].dport if pkt.haslayer(TCP) else (pkt[UDP].dport if pkt.haslayer(UDP) else 0)

        # Ignorer trafic entrant ou local
        if FastMath.is_private_ip(dst) or FastMath.is_private_ip(src):
            if FastMath.is_private_ip(dst): return alerts

        # Volume sortant
        self._bytes_out[src][dst].append((now, len(pl)))
        # Nettoyage ancien
        self._bytes_out[src][dst] = [(t, b) for t, b in self._bytes_out[src][dst] if now-t <= self.win]
        total = sum(b for _, b in self._bytes_out[src][dst])

        if total >= self.limit_bytes:
            alerts.append(Alert(
                type="data_exfil", subtype="large_outbound",
                severity="CRITICAL", confidence="high",
                source_ip=src, dest_ip=dst, port=dport,
                bytes_out=total,
                duration_s=self.win,
                detail=f"Exfiltration probable : {total//1024//1024}MB → {dst} en {self.win}s",
            ))
            # Reset compteur
            self._bytes_out[src][dst] = []

        # Port suspect + payload
        if dport in self.sus_ports and len(pl) > 1024:
            alerts.append(Alert(
                type="data_exfil", subtype="suspicious_port",
                severity="HIGH", confidence="medium",
                source_ip=src, dest_ip=dst, port=dport,
                bytes_out=len(pl),
                detail=f"Gros payload ({len(pl)}B) sur port suspect {dport}",
            ))

        # Base64 dans payload
        if self.b64_detect and len(pl) > 200:
            try:
                # Chercher des blocs base64 longs
                b64_re = re.compile(rb"[A-Za-z0-9+/]{60,}={0,2}")
                matches = b64_re.findall(pl)
                if matches and len(matches[0]) > 200:
                    alerts.append(Alert(
                        type="data_exfil", subtype="b64_encoded",
                        severity="MEDIUM", confidence="medium",
                        source_ip=src, dest_ip=dst, port=dport,
                        detail=f"Données base64 suspectes dans payload ({len(matches[0])}B) → {dst}",
                    ))
            except Exception:
                pass

        # Données compressées (zlib/gzip magic bytes)
        if self.comp_detect:
            if pl[:2] in (b"\x1f\x8b", b"\x78\x9c", b"\x78\x01", b"\x78\xda"):
                if len(pl) > 10240:
                    alerts.append(Alert(
                        type="data_exfil", subtype="compressed_transfer",
                        severity="MEDIUM", confidence="low",
                        source_ip=src, dest_ip=dst, port=dport,
                        bytes_out=len(pl),
                        detail=f"Transfert compressé suspect ({len(pl)//1024}KB) → {dst}",
                    ))

        return alerts


