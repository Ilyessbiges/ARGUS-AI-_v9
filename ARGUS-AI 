            http_uri=str(alert.http_uri or "")[:512],
            bytes_out=alert.bytes_out, pcap_file=alert.pcap_file,
        )
        try:
            with self._lock:
                with self.SessionLocal() as sess:
                    sess.merge(rec); sess.commit()
        except Exception as e:
            self.log.error("DB insert : %s", e)

    def add_blocked_ip(self, ip: str, reason: str, expires_h: Optional[int] = None) -> None:
        if not SA_OK: return
        exp = time.time() + expires_h * 3600 if expires_h else None
        try:
            with self._lock:
                with self.SessionLocal() as sess:
                    existing = sess.query(BlockedIP).filter_by(ip=ip).first()
                    if existing:
                        existing.active = True; existing.reason = reason; existing.expires_at = exp
                    else:
                        sess.add(BlockedIP(ip=ip, reason=reason, expires_at=exp))
                    sess.commit()
        except Exception as e:
            self.log.error("BlockedIP insert : %s", e)

    def get_active_blocks(self) -> List[Dict]:
        if not SA_OK: return []
        now = time.time()
        try:
            with self.SessionLocal() as sess:
                rows = sess.query(BlockedIP).filter(
                    BlockedIP.active == True,
                ).all()
                return [{"ip":r.ip,"reason":r.reason,
                         "blocked_at":r.blocked_at,"expires_at":r.expires_at}
                        for r in rows if not r.expires_at or r.expires_at > now]
        except Exception:
            return []

    def export_training_data(self, limit=50000):
        if not (SA_OK and NP_OK): return None
        SEV = {"LOW":1,"MEDIUM":2,"HIGH":3,"CRITICAL":4}
        CON = {"low":1,"medium":2,"high":3}
        try:
            with self.SessionLocal() as sess:
                rows = sess.query(AlertRecord).filter(
                    AlertRecord.risk_score.isnot(None)
                ).order_by(AlertRecord.timestamp.desc()).limit(limit).all()
            if len(rows) < 10: return None
            X, y = [], []
            for r in rows:
                ts  = datetime.utcfromtimestamp(r.timestamp)
                tod = ts.hour + ts.minute/60.0
                X.append([
                    SEV.get(r.severity or "LOW",1),
                    CON.get(r.confidence or "low",1),
                    0, 0, 0, r.port or 0,
                    math.sin(2*math.pi*tod/24), math.cos(2*math.pi*tod/24),
                    r.geo_risk or 0.0,
                    1.0 if r.threat_intel else 0.0,
                    0.0, 0.0,
                ])
                y.append(min(1.0,(r.risk_score or 0)/10.0))
            return np.array(X, dtype=np.float32), np.array(y, dtype=np.float32)
        except Exception as e:
            self.log.error("Export training : %s", e); return None

    def recent_stats(self) -> Dict:
        if not SA_OK: return {}
        since = time.time() - 86400
        try:
            with self.SessionLocal() as sess:
                rows = sess.query(
                    AlertRecord.severity, AlertRecord.type,
                    AlertRecord.source, AlertRecord.geo_country,
                    AlertRecord.threat_intel
                ).filter(AlertRecord.timestamp >= since).all()
            sev, types, sources, geo, ti = (defaultdict(int) for _ in range(5))
            for r in rows:
                sev[r.severity]+=1; types[r.type]+=1
                sources[r.source or "?"]+=1
                if r.geo_country: geo[r.geo_country]+=1
                if r.threat_intel: ti["confirmed"]+=1
            return {
                "by_severity":dict(sev), "by_type":dict(types),
                "by_source":dict(sources), "by_country":dict(geo),
                "threat_intel_hits":dict(ti), "total":len(rows),
            }
        except Exception as e:
            self.log.error("Stats : %s", e); return {}

    def get_top_attackers(self, limit=20) -> List[Dict]:
        if not SA_OK: return []
        since = time.time() - 86400
        try:
            with self.SessionLocal() as sess:
                from sqlalchemy import func as sfunc
                rows = sess.query(
                    AlertRecord.source_ip,
                    sfunc.count(AlertRecord.id).label("cnt"),
                    sfunc.max(AlertRecord.risk_score).label("max_risk"),
                    AlertRecord.geo_country,
                ).filter(
                    AlertRecord.timestamp >= since,
                    AlertRecord.source_ip.isnot(None)
                ).group_by(AlertRecord.source_ip).order_by(
                    sfunc.count(AlertRecord.id).desc()
                ).limit(limit).all()
                return [{"ip":r.source_ip,"count":r.cnt,
                         "max_risk":r.max_risk,"country":r.geo_country}
                        for r in rows]
        except Exception:
            return []


