class KaliInterfaceManager:
    def __init__(self, config: Dict):
        self.cfg    = config.get("interfaces", {})
        self.wlan0  = self.cfg.get("wlan0", "wlan0")
        self.wlan1  = self.cfg.get("wlan1", "wlan1")
        self.mon_if = self.cfg.get("monitor_iface", "wlan1mon")
        self.log    = logging.getLogger("ARGUS.Iface")
        self._mon_active = False
        self._blocked_ips: Set[str] = set()
        self._throttled:   Set[str] = set()

    def check_interfaces(self) -> Dict[str, bool]:
        result = {}
        for iface in [self.wlan0, self.wlan1]:
            path = Path(f"/sys/class/net/{iface}")
            result[iface] = path.exists()
            self.log.info("Interface %-10s : %s", iface, "✓ UP" if result[iface] else "✗ absent")
        return result

    def enable_monitor_mode(self) -> bool:
        self.log.info("Activation mode monitor sur %s...", self.wlan1)
        try:
            subprocess.run(["sudo","airmon-ng","check","kill"], capture_output=True, timeout=10)
            r = subprocess.run(["sudo","airmon-ng","start", self.wlan1],
                               capture_output=True, text=True, timeout=15)
            for line in r.stdout.splitlines():
                if "mon" in line.lower() and "enabled" in line.lower():
                    parts = line.split()
                    for p in parts:
                        if "mon" in p and p.startswith("wlan"):
                            self.mon_if = p.strip("()[]"); break
            if Path(f"/sys/class/net/{self.mon_if}").exists():
                self.log.info("Mode monitor actif : %s", self.mon_if)
                self._mon_active = True; return True
            subprocess.run(["sudo","ip","link","set",self.wlan1,"down"], capture_output=True)
            subprocess.run(["sudo","iw",self.wlan1,"set","monitor","none"], capture_output=True)
            subprocess.run(["sudo","ip","link","set",self.wlan1,"name",self.mon_if], capture_output=True)
            subprocess.run(["sudo","ip","link","set",self.mon_if,"up"], capture_output=True)
            self._mon_active = True
            self.log.info("Mode monitor actif via iw : %s", self.mon_if)
            return True
        except Exception as e:
            self.log.error("Échec mode monitor : %s", e); return False

    def disable_monitor_mode(self) -> None:
        if not self._mon_active: return
        try:
            subprocess.run(["sudo","airmon-ng","stop", self.mon_if], capture_output=True, timeout=10)
            self.log.info("Mode monitor désactivé")
        except Exception as e:
            self.log.warning("Désactivation monitor : %s", e)

    def set_channel(self, channel: int, iface: Optional[str] = None) -> None:
        iface = iface or self.mon_if
        try:
            subprocess.run(["sudo","iw","dev",iface,"set","channel",str(channel)],
                           capture_output=True, timeout=3)
        except Exception:
            pass

    def enable_ip_forwarding(self) -> None:
        try:
            subprocess.run(["sudo","sysctl","-w","net.ipv4.ip_forward=1"], capture_output=True)
            self.log.info("IP forwarding activé")
        except Exception as e:
            self.log.warning("IP forward : %s", e)

    def block_ip(self, ip: str, comment: str = "ARGUS") -> bool:
        if not ip or ip in ("127.0.0.1","::1") or ip in self._blocked_ips:
            return False
        try:
            for chain in ("INPUT", "FORWARD", "OUTPUT"):
                subprocess.run([
                    "sudo","iptables","-A",chain,"-s",ip,
                    "-j","DROP","-m","comment","--comment",comment
                ], capture_output=True)
            self._blocked_ips.add(ip)
            self.log.warning("🚫 IP BLOQUÉE [iptables] : %s (%s)", ip, comment)
            return True
        except Exception as e:
            self.log.error("Blocage IP %s : %s", ip, e); return False

    def unblock_ip(self, ip: str) -> bool:
        if ip not in self._blocked_ips: return False
        try:
            for chain in ("INPUT", "FORWARD", "OUTPUT"):
                subprocess.run([
                    "sudo","iptables","-D",chain,"-s",ip,"-j","DROP"
                ], capture_output=True)
            self._blocked_ips.discard(ip)
            self.log.info("✅ IP débloquée : %s", ip)
            return True
        except Exception as e:
            self.log.error("Déblocage IP %s : %s", ip, e); return False

    def throttle_ip(self, ip: str, kbps: int = 512) -> bool:
        """Limite la bande passante d'une IP via tc (traffic control)."""
        if ip in self._throttled: return False
        try:
            subprocess.run(["sudo","tc","qdisc","add","dev",self.wlan0,
                "root","handle","1:","htb","default","12"], capture_output=True)
            subprocess.run(["sudo","tc","class","add","dev",self.wlan0,
                "parent","1:","classid","1:1","htb","rate",f"{kbps}kbit"], capture_output=True)
            self._throttled.add(ip)
            self.log.warning("⚡ IP throttlée : %s → %dkbps", ip, kbps)
            return True
        except Exception as e:
            self.log.error("Throttle %s : %s", ip, e); return False

    def deauth_station(self, bssid: str, station: str, count: int = 5) -> None:
        if not self._mon_active: return
        try:
            subprocess.Popen([
                "sudo","aireplay-ng","--deauth",str(count),
                "-a",bssid,"-c",station,self.mon_if
            ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            self.log.warning("Déauth envoyé → %s depuis %s", station, bssid)
        except Exception as e:
            self.log.error("Déauth : %s", e)

    def add_honeypot_rule(self, ip: str) -> None:
        """Redirige l'IP vers un honeypot local (port 9999)."""
        try:
            subprocess.run([
                "sudo","iptables","-t","nat","-A","PREROUTING",
                "-s",ip,"-j","REDIRECT","--to-port","9999"
            ], capture_output=True)
            self.log.warning("🍯 IP redirigée vers honeypot : %s", ip)
        except Exception as e:
            self.log.error("Honeypot redirect : %s", e)

    def get_connected_aps(self) -> List[Dict]:
        try:
            r = subprocess.run(["iw","dev",self.wlan0,"scan"],
                               capture_output=True, text=True, timeout=10)
            aps = []; current: Dict = {}
            for line in r.stdout.splitlines():
                line = line.strip()
                if line.startswith("BSS "):
                    if current: aps.append(current)
                    current = {"bssid": line.split()[1].split("(")[0]}
                elif "SSID:" in line:
                    current["ssid"] = line.split("SSID:")[1].strip()
                elif "freq:" in line:
                    current["freq"] = line.split("freq:")[1].strip()
                elif "signal:" in line:
                    current["signal"] = line.split("signal:")[1].strip()
            if current: aps.append(current)
            return aps
        except Exception:
            return []

    @property
    def blocked_ips(self) -> Set[str]:
        return frozenset(self._blocked_ips)


