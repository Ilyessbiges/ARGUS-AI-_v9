class RLResponseAgent:
    SEV  = {"LOW":1,"MEDIUM":2,"HIGH":3,"CRITICAL":4}
    CONF = {"low":1,"medium":2,"high":3}

    def __init__(self, config):
        self.enabled = config.get("enabled",False) and SK_OK and NP_OK
        self.log = logging.getLogger("ARGUS.RL")
        if not self.enabled: return
        self.lr      = config.get("learning_rate",0.05)
        self.eps     = config.get("epsilon",0.15)
        self.eps_dec = config.get("epsilon_decay",0.9995)
        self.eps_min = config.get("epsilon_min",0.01)
        self.rw      = config.get("reward_window",120)
        self.feats   = config.get("features",["severity_score","confidence_score",
                                               "alert_frequency","distinct_alert_types",
                                               "geo_risk","threat_intel_score"])
        self.actions = config.get("actions",["allow","throttle","block","isolate","honeypot"])
        self.spath   = config.get("model_save_path","output/rl_model.pkl")
        self._aidx   = {a:i for i,a in enumerate(self.actions)}
        nf = len(self.feats)
        self._iph: Dict[str,deque] = defaultdict(lambda: deque(maxlen=200))
        self._pend: Dict[str,List] = {}
        self._lock = threading.Lock()
        self.scaler = StandardScaler()
        self.qm = [SGDRegressor(learning_rate="constant",eta0=self.lr,warm_start=True) for _ in self.actions]
        dummy = np.zeros((2,nf)); dummy[1,0]=1.0
        self.scaler.fit(dummy)
        for m in self.qm: m.fit(dummy,[0.0,0.0])
        self._load()
        self.log.info("RL actif | actions=%s | ε=%.2f", self.actions, self.eps)

    def _state(self, alert, ip):
        h = self._iph.get(ip, deque()); now = time.time()
        freq  = sum(1 for ts,_ in h if now-ts<300)
        types = len(set(t for _,t in h if now-_<300))
        vec = []
        for f in self.feats:
            if f=="severity_score":        vec.append(self.SEV.get(alert.severity,1))
            elif f=="confidence_score":    vec.append(self.CONF.get(alert.confidence,1))
            elif f=="alert_frequency":     vec.append(min(freq,50))
            elif f=="distinct_alert_types":vec.append(min(types,10))
            elif f=="geo_risk":            vec.append(alert.geo_risk)
            elif f=="threat_intel_score":  vec.append(1.0 if alert.threat_intel else 0.0)
            else:                          vec.append(0.0)
        return np.array(vec,dtype=float).reshape(1,-1)

    def select_action(self, alert):
        if not self.enabled: return "allow"
        ip = alert.source_ip or alert.bssid or "?"
        raw = self._state(alert,ip); sc = self.scaler.transform(raw)
        action = (random.choice(self.actions) if np.random.random()<self.eps
                  else self.actions[int(np.argmax([m.predict(sc)[0] for m in self.qm]))])
        self.eps = max(self.eps_min, self.eps*self.eps_dec)
        with self._lock:
            self._iph[ip].append((time.time(),alert.type))
            self._pend[ip] = [action, sc, time.time(), {alert.type}]
        return action

    def record_repeat(self, ip, alert_type):
        if not self.enabled: return
        with self._lock:
            if ip not in self._pend: return
            action,state,_,types = self._pend[ip]
            types.add(alert_type)
            r = -1.0 if action in ("block","isolate","honeypot") else -0.5
            self._update(ip,action,state,r)

    def evaluate_pending(self):
        if not self.enabled: return
        now = time.time()
        with self._lock:
            for ip,(action,state,ts,types) in list(self._pend.items()):
                if now-ts >= self.rw:
                    r = +2.0 if action in ("block","isolate","honeypot") else +0.5
                    self._update(ip,action,state,r)
                    del self._pend[ip]

    def _update(self, ip, action, state, reward):
        self.qm[self._aidx.get(action,0)].partial_fit(state,[reward])
        self._save()

    def _save(self):
        try:
            Path(self.spath).parent.mkdir(parents=True, exist_ok=True)
            with open(self.spath,"wb") as f:
                pickle.dump({"scaler":self.scaler,"models":self.qm,
                             "epsilon":self.eps,"actions":self.actions},f)
        except Exception: pass

    def _load(self):
        if not Path(self.spath).exists(): return
        try:
            with open(self.spath,"rb") as f: d=pickle.load(f)
            self.scaler=d["scaler"]; self.qm=d["models"]; self.eps=d.get("epsilon",self.eps)
        except Exception as e: self.log.warning("RL load : %s",e)

    @property
    def status(self):
        return {"enabled":self.enabled,"epsilon":round(self.eps,4),
                "pending_ips":len(self._pend) if self.enabled else 0,
                "actions":self.actions}


