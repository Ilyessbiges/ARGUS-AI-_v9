    +' | '+a.brain.risk_score+'/10 ['+a.brain.scored_by+']'
    +(a.brain.escalate?' ⚠ESC':'')
    +(a.brain.kill_chain_stages>1?' 🔗KC:'+a.brain.kill_chain_stages:'')+'</div>';
  var extra='';
  if(a.ssid) extra+='<div class="cb" style="color:var(--wifi)">📶 '+a.ssid+(a.channel?' CH'+a.channel:'')+(a.rssi?' '+a.rssi+'dBm':'')+'</div>';
  if(a.geo_country&&!isWifi) extra+='<div class="cb" style="color:var(--geo)">🌍 '+a.geo_country+(a.geo_city?' / '+a.geo_city:'')+'</div>';
  if(a.http_uri) extra+='<div class="cb" style="color:var(--high)">🌐 '+a.http_method+' '+a.http_uri.slice(0,60)+'</div>';

  var isTI=a.threat_intel;
  var card=document.createElement('div');
  card.className='card '+sev+(isWifi?' wifi':'')+(isTI?' ti_hit':'');
  card.innerHTML='<div class="cr"><span class="ct">'+(a.type||'').replace(/_/g,' ')
    +mitre+srcBadge+rl_b+lg_b+wf_b+llm_b+ti_b+geo_b+'</span>'
    +'<span style="color:var(--dim);font-size:.62rem">'+ts+'</span></div>'
    +'<div style="font-size:.67rem;color:var(--text)">'+(a.source_ip||a.mac_src||a.domain||'')+'</div>'
