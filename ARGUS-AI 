class DatabaseManager:
    def __init__(self, config: Dict):
        self.log = logging.getLogger("ARGUS.DB")
        self._counter = 0
        if not SA_OK:
            self.engine = self.SessionLocal = None; return
        db_cfg = config.get("database", {})
        url    = db_cfg.get("url", "sqlite:///output/argus.db")
        Path("output").mkdir(exist_ok=True)
        if url.startswith("sqlite"):
            self.engine = create_engine(url, echo=db_cfg.get("echo", False),
                connect_args={"check_same_thread": False}, poolclass=StaticPool)
        else:
            self.engine = create_engine(url, echo=db_cfg.get("echo", False),
                pool_size=db_cfg.get("pool_size", 5), max_overflow=10)
        Base.metadata.create_all(self.engine)
        self.SessionLocal = sessionmaker(bind=self.engine)
        if url.startswith("sqlite") and db_cfg.get("wal_mode", True):
            with self.engine.connect() as conn:
                conn.execute(text("PRAGMA journal_mode=WAL"))
                conn.execute(text("PRAGMA synchronous=NORMAL"))
                conn.execute(text("PRAGMA cache_size=-64000"))
                conn.execute(text("PRAGMA temp_store=MEMORY"))
                conn.commit()
            self.log.info("SQLite WAL + optimisations activées")
        with self.SessionLocal() as sess:
            if not sess.get(IncidentCounter, 1):
                sess.add(IncidentCounter(id=1, value=0)); sess.commit()
        self._lock = threading.Lock()
        self.log.info("DB prête : %s", url.split("///")[-1])

    def next_incident_id(self) -> str:
        if not SA_OK:
            self._counter += 1
            return f"INC-{self._counter:06d}"
        with self._lock:
            with self.SessionLocal() as sess:
                c = sess.get(IncidentCounter, 1)
                c.value += 1; val = c.value; sess.commit()
        return f"INC-{val:06d}"

    def insert_alert(self, alert: Alert, inc_id: str) -> None:
        if not SA_OK: return
        brain = alert.brain or {}
        llm_s = None
        if alert.llm_analysis:
            llm_s = json.dumps({
                "risk_score": alert.llm_analysis.get("risk_score"),
                "fp":         alert.llm_analysis.get("false_positive_likelihood"),
                "kill_chain": alert.llm_analysis.get("kill_chain_phase","?"),
                "playbook":   alert.llm_analysis.get("recommended_playbook","?"),
                "expl":       str(alert.llm_analysis.get("explanation",""))[:500],
            })
        rec = AlertRecord(
            incident_id=inc_id, timestamp=alert.timestamp,
            type=alert.type, subtype=alert.subtype,
            severity=alert.severity, confidence=alert.confidence,
            source_ip=alert.source_ip, dest_ip=alert.dest_ip,
            domain=alert.domain, port=alert.port,
            fingerprint=alert.fingerprint, cve_id=alert.cve_id,
            mitre_id=alert.mitre_id, mitre_tactic=alert.mitre_tactic,
            kill_chain=alert.kill_chain,
            risk_score=brain.get("risk_score"), lgbm_score=alert.lgbm_score,
            action=alert.action, detail=str(alert.detail)[:1000],
            llm_summary=llm_s, raw_json=alert.serialize()[:8000],
            source=alert.source, bssid=alert.bssid,
            ssid=alert.ssid, channel=alert.channel,
            geo_country=alert.geo_country, geo_city=alert.geo_city,
            geo_risk=alert.geo_risk,
            threat_intel=alert.threat_intel, ioc_match=alert.ioc_match,
