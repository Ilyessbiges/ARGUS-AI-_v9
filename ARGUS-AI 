# SECTION 22 — ZEEK CONSUMER (enrichi HTTP/SSH)
# ══════════════════════════════════════════════════════════════════════════════

class ZeekConsumer:
    HANDLERS = {"dns.log":"_dns","ssl.log":"_ssl","conn.log":"_conn",
                "files.log":"_files","weird.log":"_weird",
                "http.log":"_http","ssh.log":"_ssh"}
    SUSPECT_MIME = frozenset({"application/x-dosexec","application/x-elf",
                              "application/x-msdownload","application/octet-stream"})
    RAT_PORTS = {4444,1337,31337,9001,9002}

    def __init__(self, config, dns_d, dga_d, tls_d):
        self.log_dir = Path(config.get("log_dir","/opt/zeek/logs/current"))
        self.logs    = config.get("logs",["dns.log","ssl.log","conn.log","http.log","ssh.log"])
        self.poll    = config.get("poll_interval",0.5)
        self.dns=dns_d; self.dga=dga_d; self.tls=tls_d
        self._stop = threading.Event()
        self._q: queue.Queue = queue.Queue(maxsize=2000)
        self._fpos: Dict[str,int] = {}
        self.log = logging.getLogger("ARGUS.Zeek")

    def start(self):
        threading.Thread(target=self._poll, daemon=True, name="Zeek").start()
        self.log.info("Zeek consumer actif : %s", self.log_dir)

    def stop(self): self._stop.set()

    def get_alerts(self):
        out = []
        try:
            while True: out.append(self._q.get_nowait())
        except queue.Empty: pass
        return out

    def _poll(self):
        while not self._stop.is_set():
            for name in self.logs:
                h = self.HANDLERS.get(name)
                if not h: continue
                p = self.log_dir / name
                if not p.exists(): continue
                try:
                    pos = self._fpos.get(str(p),0)
                    with open(p,"r",errors="replace") as f:
                        f.seek(pos)
                        for line in f:
                            line = line.strip()
                            if not line or line.startswith("#"): continue
                            try:
                                rec = json.loads(line)
                                fn  = getattr(self, h, None)
                                if fn:
                                    for a in (fn(rec) or []):
                                        a.source = "zeek"
                                        try: self._q.put_nowait(a)
                                        except queue.Full: pass
                            except (json.JSONDecodeError,KeyError): pass
                        self._fpos[str(p)] = f.tell()
                except (OSError,IOError): pass
            time.sleep(self.poll)

    def _dns(self, r):
        dom = r.get("query",""); alerts = []
        if not dom: return alerts
        for fn in (self.dns.analyze, self.dga.analyze):
            a = fn(dom)
            if a: a.source_ip = r.get("id.orig_h"); alerts.append(a)
        return alerts

    def _ssl(self, r):
        ja3 = r.get("ja3","")
        if not ja3: return []
        a = self.tls.analyze(ja3)
        if a:
            a.source_ip = r.get("id.orig_h"); a.dest_ip = r.get("id.resp_h")
            a.detail += f" | SNI={r.get('server_name','?')}"
        return [a] if a else []

    def _conn(self, r):
        dp = int(r.get("id.resp_p",0))
        if dp not in self.RAT_PORTS: return []
        return [Alert(type="backdoor_behavior",subtype="rat_port",
            severity="HIGH",confidence="medium",
            source_ip=r.get("id.orig_h"),dest_ip=r.get("id.resp_h"),port=dp,
            detail=f"[Zeek] Port RAT {dp} | dur={r.get('duration','?')}s | bytes={r.get('resp_bytes','?')}")]

    def _files(self, r):
        mime = r.get("mime_type","")
        if mime not in self.SUSPECT_MIME: return []
        tx = r.get("tx_hosts",[None])
        return [Alert(type="zeek_file",subtype="suspect_transfer",
            severity="HIGH",confidence="medium",
            source_ip=tx[0] if tx else None,
            detail=f"[Zeek] Transfert suspect : {mime} ({r.get('total_bytes','?')}B)")]

    def _weird(self, r):
        name = r.get("name","?")
        return [Alert(type="zeek_weird",subtype=name,severity="MEDIUM",confidence="medium",
            source_ip=r.get("id.orig_h"),
            detail=f"[Zeek] Anomalie : {name} | {r.get('addl','')}")]

    def _http(self, r):
        """Analyse les logs HTTP Zeek pour SQLi/XSS/Path Traversal."""
        uri = r.get("uri",""); method = r.get("method",""); ua = r.get("user_agent","").lower()
        alerts = []
        sqli_re = re.compile(r"(?:union.+select|insert.+into|drop.+table|xp_cmdshell)", re.I)
        if sqli_re.search(uri):
            alerts.append(Alert(
                type="http_sqli", severity="CRITICAL", confidence="high",
                source_ip=r.get("id.orig_h"), dest_ip=r.get("id.resp_h"),
                port=int(r.get("id.resp_p",80)),
                http_method=method, http_uri=uri[:256],
                detail=f"[Zeek] SQLi dans URI : {uri[:80]}",
            ))
        bad_uas = ["sqlmap","nikto","masscan","havij","w3af","dirbuster"]
        if any(b in ua for b in bad_uas):
            alerts.append(Alert(
                type="port_scan", subtype="http_scanner",
                severity="MEDIUM", confidence="high",
                source_ip=r.get("id.orig_h"),
                http_ua=ua[:128],
                detail=f"[Zeek] Scanner HTTP UA='{ua[:60]}'",
            ))
        return alerts

    def _ssh(self, r):
        """Détecte les brute-force SSH via logs Zeek."""
        if r.get("auth_success") == False:
            return [Alert(
                type="ssh_bruteforce", subtype="zeek_fail",
                severity="MEDIUM", confidence="medium",
                source_ip=r.get("id.orig_h"), dest_ip=r.get("id.resp_h"),
                port=22,
                detail=f"[Zeek] Échec auth SSH | client={r.get('client','?')} | user={r.get('auth_attempts','?')} tentatives",
            )]
        return []


