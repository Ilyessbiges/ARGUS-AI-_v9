class WiFiDetector:
    def __init__(self, config: Dict):
        self.cfg           = config.get("wifi", {})
        self.deauth_thresh = self.cfg.get("deauth_threshold", 10)
        self.probe_thresh  = self.cfg.get("probe_threshold", 20)
        self.detect_pmkid  = self.cfg.get("pmkid_detect", True)
        self.detect_twin   = self.cfg.get("evil_twin_detect", True)
        self.log           = logging.getLogger("ARGUS.WiFi")
        self._deauth:     Dict[str, deque] = defaultdict(lambda: deque(maxlen=200))
        self._probes:     Dict[str, deque] = defaultdict(lambda: deque(maxlen=200))
        self._aps:        Dict[str, str]   = {}
        self._ap_channels:Dict[str, int]   = {}
        self._handshakes: Dict[str, List]  = defaultdict(list)
        self._arp_cache:  Dict[str, str]   = {}
        self._deauth_targets: Dict[str, Set[str]] = defaultdict(set)

    def analyze(self, pkt) -> List[Alert]:
        if not SCAPY_OK: return []
        alerts: List[Alert] = []
        if pkt.haslayer(Dot11Beacon):        alerts.extend(self._check_beacon(pkt))
        elif pkt.haslayer(Dot11Deauth):      alerts.extend(self._check_deauth(pkt))
        elif pkt.haslayer(Dot11ProbeReq):    alerts.extend(self._check_probe(pkt))
        elif pkt.haslayer(EAPOL):            alerts.extend(self._check_eapol(pkt))
        elif pkt.haslayer(ARP):              alerts.extend(self._check_arp(pkt))
        return alerts

    def _get_ssid(self, pkt) -> str:
        try: return pkt[Dot11Elt].info.decode("utf-8", errors="replace")
        except Exception: return "?"

    def _get_rssi(self, pkt) -> Optional[int]:
        try: return -(256 - pkt[RadioTap].dBm_AntSignal) if pkt.haslayer(RadioTap) else None
        except Exception: return None

    def _check_beacon(self, pkt) -> List[Alert]:
        alerts = []
        if not self.detect_twin: return alerts
        try:
            ssid  = self._get_ssid(pkt)
            bssid = pkt[Dot11].addr3 or pkt[Dot11].addr2
            rssi  = self._get_rssi(pkt)
            if not ssid or ssid == "?": return alerts
            if ssid in self._aps and self._aps[ssid] != bssid:
                alerts.append(Alert(
                    type="wifi_evil_twin", severity="CRITICAL", confidence="high",
                    bssid=bssid, ssid=ssid, rssi=rssi, source="wlan1",
                    detail=f"Evil Twin AP ! SSID='{ssid}' | Légitime={self._aps[ssid]} | Rogue={bssid}",
                ))
            else:
                self._aps[ssid] = bssid
        except Exception: pass
        return alerts

    def _check_deauth(self, pkt) -> List[Alert]:
        alerts = []
        try:
            src = pkt[Dot11].addr2 or "?"; dst = pkt[Dot11].addr1 or "?"
            now = time.time()
            self._deauth[src].append(now)
            self._deauth_targets[src].add(dst)
            recent = sum(1 for t in self._deauth[src] if now-t < 30)
            if recent >= self.deauth_thresh:
                sev = "CRITICAL" if len(self._deauth_targets[src]) > 3 else "HIGH"
                alerts.append(Alert(
                    type="wifi_deauth", severity=sev, confidence="high",
                    mac_src=src, mac_dst=dst, source="wlan1",
                    detail=f"Deauth flood : {recent}/30s | {len(self._deauth_targets[src])} cibles | src={src}",
                ))
        except Exception: pass
        return alerts

    def _check_probe(self, pkt) -> List[Alert]:
        alerts = []
        try:
            mac = pkt[Dot11].addr2 or "?"; now = time.time()
            self._probes[mac].append(now)
            recent = sum(1 for t in self._probes[mac] if now-t < 60)
            if recent >= self.probe_thresh:
                alerts.append(Alert(
                    type="wifi_probe", severity="MEDIUM", confidence="medium",
                    mac_src=mac, source="wlan1",
                    detail=f"Probe flood : {recent}/60s depuis {mac} — scan passif de réseaux",
                ))
        except Exception: pass
        return alerts

    def _check_eapol(self, pkt) -> List[Alert]:
        alerts = []
        try:
            bssid = pkt[Dot11].addr3 or pkt[Dot11].addr1 or "?"
            self._handshakes[bssid].append(time.time())
            times = [t for t in self._handshakes[bssid] if time.time()-t < 5]
            if len(times) >= 4:
                alerts.append(Alert(
                    type="wifi_handshake", severity="HIGH", confidence="high",
                    bssid=bssid, source="wlan1",
                    detail=f"Handshake WPA2 capturé (EAPOL 4-way) — BSSID={bssid} — cracking possible",
                ))
                self._handshakes[bssid] = []
            if self.detect_pmkid and pkt.haslayer(Raw):
                raw = bytes(pkt[Raw].load)
                if b"\xdd\x16\x00\x0f\xac" in raw or (len(raw) > 80 and raw[4] == 3):
                    alerts.append(Alert(
                        type="wifi_pmkid", severity="CRITICAL", confidence="medium",
                        bssid=bssid, source="wlan1",
                        detail=f"Attaque PMKID détectée — BSSID={bssid} — WPA2/3 cracking sans handshake",
                    ))
        except Exception: pass
        return alerts

    def _check_arp(self, pkt) -> List[Alert]:
        alerts = []
        try:
            arp = pkt[ARP]; ip = arp.psrc; mac = arp.hwsrc
            if not ip or not mac: return alerts
            if ip in self._arp_cache and self._arp_cache[ip] != mac:
                alerts.append(Alert(
                    type="arp_spoofing", severity="HIGH", confidence="high",
                    source_ip=ip, mac_src=mac, source="wlan0",
                    detail=f"ARP Spoofing : {ip} → MAC {self._arp_cache[ip]} → {mac}",
                ))
            self._arp_cache[ip] = mac
        except Exception: pass
        return alerts


