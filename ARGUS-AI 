class PCAPExporter:
    """
    Capture et sauvegarde automatiquement les paquets suspects en fichiers PCAP
    pour analyse forensique ultérieure (Wireshark, tcpdump...).
    """
    SEV_RANK = {"LOW":1,"MEDIUM":2,"HIGH":3,"CRITICAL":4}

    def __init__(self, config: Dict):
        cfg            = config.get("pcap", {})
        self.enabled   = cfg.get("enabled", True) and SCAPY_OK
        self.auto      = cfg.get("auto_capture", True)
        self.max_bytes = cfg.get("max_size_mb", 100) * 1024 * 1024
        self.rotate    = cfg.get("rotate_count", 10)
        self.min_sev   = cfg.get("min_severity", "HIGH")
        self.out_dir   = Path(config.get("pcap_dir", "output/pcap"))
        self.out_dir.mkdir(parents=True, exist_ok=True)
        self.log       = logging.getLogger("ARGUS.PCAP")
        self._writers: Dict[str, Any] = {}
        self._sizes:   Dict[str, int] = {}
        self._lock     = threading.Lock()

    def _get_writer(self, key: str, label: str) -> Optional[Any]:
        if not self.enabled: return None
        if key not in self._writers:
            fname = self.out_dir / f"{label}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.pcap"
            try:
                self._writers[key] = (str(fname), open(fname, "wb"))
                self._sizes[key]   = 0
                self.log.info("PCAP ouvert : %s", fname.name)
            except Exception as e:
                self.log.error("PCAP open : %s", e); return None
        return self._writers[key]

    def capture(self, pkt, alert: Alert) -> Optional[str]:
        if not (self.enabled and self.auto): return None
        if self.SEV_RANK.get(alert.severity, 0) < self.SEV_RANK.get(self.min_sev, 3): return None
        key   = f"{alert.type}_{alert.source_ip or 'unk'}"
        label = f"{alert.type}_{(alert.source_ip or 'unk').replace('.','_')}"
        with self._lock:
            result = self._get_writer(key, label)
            if not result: return None
            fname, fobj = result
            try:
                wrpcap(fname, [pkt], append=True)
                self._sizes[key] = self._sizes.get(key, 0) + len(bytes(pkt))
                # Rotation si trop grand
                if self._sizes[key] >= self.max_bytes:
                    fobj.close()
                    del self._writers[key], self._sizes[key]
                    self.log.info("PCAP rotaté : %s", fname)
                return fname
            except Exception:
                return None

    def list_captures(self) -> List[Dict]:
        captures = []
        for f in self.out_dir.glob("*.pcap"):
            captures.append({
                "file": f.name,
                "size_kb": f.stat().st_size // 1024,
                "modified": datetime.fromtimestamp(f.stat().st_mtime).isoformat(),
            })
        return sorted(captures, key=lambda x: x["modified"], reverse=True)


