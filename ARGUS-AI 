# SECTION 9 — PORT SCAN DETECTOR
# ══════════════════════════════════════════════════════════════════════════════

class PortScanDetector:
    """
    Détecte :
    - SYN Scan (half-open) : beaucoup de SYN sans ACK
    - FIN/NULL/XMAS Scan : flags anormaux
    - UDP Scan : flood UDP vers ports variés
    - Service Scan : connexions vers ports sensibles connus
    - Vertical scan (même IP, beaucoup de ports)
    - Horizontal scan (même port, beaucoup d'IPs — Nmap -p 22 192.168.0.0/24)
    """
    SENSITIVE_PORTS = frozenset({
        21,22,23,25,53,80,110,111,135,137,139,143,161,389,
        443,445,512,513,514,873,993,995,1080,1433,1521,
        2049,3306,3389,5432,5900,6379,8080,8443,27017
    })

    def __init__(self, config: Dict):
        cfg = config.get("port_scan", {})
        self.enabled         = cfg.get("enabled", True)
        self.syn_thresh      = cfg.get("syn_threshold", 50)
        self.fin_thresh      = cfg.get("fin_udp_threshold", 30)
        self.win             = cfg.get("time_window", 10)
        self.xmas_detect     = cfg.get("xmas_detect", True)
        self.null_detect     = cfg.get("null_detect", True)
        self.log             = logging.getLogger("ARGUS.PortScan")
        # {src_ip: {dst_ip: set(ports)}}
        self._syn:  Dict[str, Dict[str, deque]] = defaultdict(lambda: defaultdict(lambda: deque(maxlen=2000)))
        self._udp:  Dict[str, deque] = defaultdict(lambda: deque(maxlen=2000))
        self._horiz:Dict[str, deque] = defaultdict(lambda: deque(maxlen=2000))   # port → [src_ips]
        self._ports:Dict[str, Set[int]] = defaultdict(set)  # src → {ports}
        self._ts:   Dict[str, deque]  = defaultdict(lambda: deque(maxlen=2000))
        self._lock  = threading.Lock()

    def analyze(self, pkt) -> List[Alert]:
        if not (self.enabled and SCAPY_OK): return []
        if not pkt.haslayer(IP): return []
        alerts: List[Alert] = []
        src = pkt[IP].src; dst = pkt[IP].dst
        now = time.time()

        # ── ICMP flood ────────────────────────────────────────────────────
        if pkt.haslayer(ICMP):
            with self._lock:
                self._ts[src].append(now)
                rate = FastMath.sliding_rate(self._ts[src], 5)
            if rate > 100:
                alerts.append(Alert(
                    type="icmp_flood", severity="MEDIUM", confidence="high",
                    source_ip=src, dest_ip=dst,
                    detail=f"ICMP flood : {rate} paquets/5s depuis {src}",
                ))

        # ── TCP ───────────────────────────────────────────────────────────
        if pkt.haslayer(TCP):
            tcp = pkt[TCP]
            flags = tcp.flags
            dport = tcp.dport; sport = tcp.sport

            # XMAS Scan (FIN+PSH+URG)
            if self.xmas_detect and flags & 0x29 == 0x29:
                alerts.append(Alert(
                    type="port_scan", subtype="xmas_scan",
                    severity="HIGH", confidence="high",
                    source_ip=src, dest_ip=dst, port=dport,
                    detail=f"XMAS scan depuis {src} → {dst}:{dport}",
                ))

            # NULL Scan (aucun flag)
            if self.null_detect and int(flags) == 0:
                alerts.append(Alert(
                    type="port_scan", subtype="null_scan",
                    severity="HIGH", confidence="high",
                    source_ip=src, dest_ip=dst, port=dport,
                    detail=f"NULL scan depuis {src} → {dst}:{dport}",
                ))

            # SYN Scan
            if flags & 0x02 and not (flags & 0x10):  # SYN sans ACK
                with self._lock:
                    self._syn[src][dst].append((now, dport))
                    self._ports[src].add(dport)
                    recent_ports = {p for t,p in self._syn[src][dst] if now-t <= self.win}
                if len(recent_ports) >= self.syn_thresh:
                    alerts.append(Alert(
                        type="port_scan", subtype="syn_scan",
                        severity="HIGH", confidence="high",
                        source_ip=src, dest_ip=dst,
                        scanned_ports=sorted(list(recent_ports))[:50],
                        detail=f"SYN scan : {len(recent_ports)} ports en {self.win}s depuis {src}",
                    ))

            # Accès à port sensible
            if dport in self.SENSITIVE_PORTS and flags & 0x02:
                alerts.append(Alert(
                    type="port_scan", subtype="sensitive_port",
                    severity="LOW", confidence="medium",
                    source_ip=src, dest_ip=dst, port=dport,
                    detail=f"Connexion vers port sensible {dport} depuis {src}",
                ))

        # ── UDP Scan ──────────────────────────────────────────────────────
        if pkt.haslayer(UDP):
            dport = pkt[UDP].dport
            with self._lock:
                self._udp[src].append((now, dport))
                recent_ports = {p for t,p in self._udp[src] if now-t <= self.win}
            if len(recent_ports) >= self.fin_thresh:
                alerts.append(Alert(
                    type="port_scan", subtype="udp_scan",
                    severity="MEDIUM", confidence="medium",
                    source_ip=src, dest_ip=dst,
                    scanned_ports=sorted(list(recent_ports))[:50],
                    detail=f"UDP scan : {len(recent_ports)} ports en {self.win}s depuis {src}",
                ))

        return alerts


