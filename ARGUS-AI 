# SECTION 11 — HTTP ANOMALY DETECTOR
# ══════════════════════════════════════════════════════════════════════════════

class HTTPAnomalyDetector:
    """
    Détecte les attaques HTTP :
    - SQL Injection (SQLi)
    - Cross-Site Scripting (XSS)
    - Path Traversal / LFI / RFI
    - Remote Code Execution (RCE)
    - User-Agent anormaux (scanners : Nikto, sqlmap, Burp)
    - Méthodes HTTP anormales
    - Fuzzing / Dirbuster patterns
    """
    SQLI_PATTERNS = [
        rb"(?:union\s+select|select\s+.*\s+from|insert\s+into|drop\s+table)",
        rb"(?:or\s+1\s*=\s*1|and\s+1\s*=\s*1|'\s*or\s*'1'\s*=\s*'1)",
        rb"(?:exec\s*\(|execute\s*\(|sp_executesql)",
        rb"(?:xp_cmdshell|benchmark\s*\(|sleep\s*\()",
        rb"(?:information_schema|sys\.tables|pg_sleep)",
        rb"(?:;\s*drop|;\s*truncate|;\s*delete\s+from)",
    ]
    XSS_PATTERNS = [
        rb"<script[^>]*>",
        rb"javascript\s*:",
        rb"(?:onerror|onload|onmouseover|onfocus)\s*=",
        rb"(?:eval\s*\(|document\.cookie|document\.write)",
        rb"(?:<iframe|<object|<embed|<svg\s+on)",
        rb"(?:alert\s*\(|confirm\s*\(|prompt\s*\()",
    ]
    PATH_TRAVERSAL = [
        rb"(?:\.\.[\\/]){2,}",
        rb"(?:%2e%2e[\\/]|%2f|%5c){2,}",
        rb"(?:/etc/passwd|/etc/shadow|/proc/self)",
        rb"(?:win\.ini|system32|cmd\.exe)",
        rb"(?:php://filter|php://input|file://)",
        rb"(?:data://text|zip://|expect://)",
    ]
    RCE_PATTERNS = [
        rb"(?:;ls |;cat |;id;|;pwd;|`ls`|`id`|\$\(id\))",
        rb"(?:system\s*\(|passthru\s*\(|shell_exec\s*\(|exec\s*\()",
        rb"(?:\|\|wget\s|\|\|curl\s|;wget\s|;curl\s)",
        rb"(?:python\s+-c|perl\s+-e|ruby\s+-e|php\s+-r)",
        rb"(?:base64\s+-d\s|bash\s+-i|sh\s+-i)",
    ]
    BAD_UAS = [
        "nikto", "sqlmap", "masscan", "nmap scripting",
        "burpsuite", "havij", "acunetix", "w3af", "dirbuster",
        "gobuster", "ffuf", "wfuzz", "nuclei", "metasploit",
        "python-requests/2.", "zgrab", "zgrab2",
    ]
    DANGEROUS_METHODS = frozenset({"TRACE","TRACK","CONNECT","PROPFIND","PROPPATCH","MKCOL"})

    def __init__(self, config: Dict):
        cfg            = config.get("http_anomaly", {})
        self.enabled   = cfg.get("enabled", True)
        self.sqli      = cfg.get("sqli_detect", True)
        self.xss       = cfg.get("xss_detect", True)
        self.traversal = cfg.get("path_traversal", True)
        self.rce       = cfg.get("rce_detect", True)
        self.ua_check  = cfg.get("ua_anomaly", True)
        self.meth      = cfg.get("method_anomaly", True)
        self.log       = logging.getLogger("ARGUS.HTTP")
        self._sqli_re  = [re.compile(p, re.I) for p in self.SQLI_PATTERNS]
        self._xss_re   = [re.compile(p, re.I) for p in self.XSS_PATTERNS]
        self._pt_re    = [re.compile(p, re.I) for p in self.PATH_TRAVERSAL]
        self._rce_re   = [re.compile(p, re.I) for p in self.RCE_PATTERNS]

    def analyze(self, pkt) -> List[Alert]:
        if not (self.enabled and SCAPY_OK): return []
        if not (pkt.haslayer(IP) and pkt.haslayer(TCP) and pkt.haslayer(Raw)): return []
        tcp = pkt[TCP]
        if tcp.dport not in (80, 8080, 8000, 8888, 443, 8443): return []
        alerts: List[Alert] = []
        src = pkt[IP].src; dst = pkt[IP].dst
        try:
            payload = bytes(pkt[Raw].load)
            decoded = unquote(payload.decode(errors="replace"))
        except Exception:
            return alerts

        # Parse HTTP request line
        method = uri = ua = ""
        lines = decoded.split("\r\n")
        if lines:
            parts = lines[0].split(" ")
            if len(parts) >= 2:
                method = parts[0].upper(); uri = parts[1]
        for line in lines:
            if line.lower().startswith("user-agent:"):
                ua = line.split(":",1)[1].strip().lower()

        # Méthode dangereuse
        if self.meth and method in self.DANGEROUS_METHODS:
            alerts.append(Alert(
                type="http_rce", subtype="dangerous_method",
                severity="MEDIUM", confidence="high",
                source_ip=src, dest_ip=dst, port=tcp.dport,
                http_method=method, http_uri=uri[:256],
                detail=f"Méthode HTTP dangereuse : {method} {uri[:60]}",
            ))

        # User-Agent malveillant
        if self.ua_check and ua:
            for bad in self.BAD_UAS:
                if bad in ua:
                    alerts.append(Alert(
                        type="port_scan", subtype="http_scanner",
                        severity="MEDIUM", confidence="high",
                        source_ip=src, dest_ip=dst, port=tcp.dport,
                        http_method=method, http_ua=ua[:128],
                        detail=f"Scanner HTTP détecté : UA='{ua[:60]}'",
                    ))
                    break

        payload_lower = payload.lower()

        # SQLi
        if self.sqli:
            for r in self._sqli_re:
                if r.search(payload_lower):
                    alerts.append(Alert(
                        type="http_sqli", severity="CRITICAL", confidence="high",
                        source_ip=src, dest_ip=dst, port=tcp.dport,
                        http_method=method, http_uri=uri[:256],
                        detail=f"SQL Injection détectée : {uri[:80]}",
                    ))
                    break

        # XSS
        if self.xss:
            for r in self._xss_re:
                if r.search(payload_lower):
                    alerts.append(Alert(
                        type="http_xss", severity="HIGH", confidence="high",
                        source_ip=src, dest_ip=dst, port=tcp.dport,
                        http_method=method, http_uri=uri[:256],
                        detail=f"XSS détecté dans la requête : {uri[:80]}",
                    ))
                    break

        # Path Traversal
        if self.traversal:
            for r in self._pt_re:
                if r.search(payload_lower):
                    alerts.append(Alert(
                        type="http_path_traversal", severity="HIGH", confidence="high",
                        source_ip=src, dest_ip=dst, port=tcp.dport,
                        http_method=method, http_uri=uri[:256],
                        detail=f"Path Traversal / LFI détecté : {uri[:80]}",
                    ))
                    break

        # RCE
        if self.rce:
            for r in self._rce_re:
                if r.search(payload_lower):
                    alerts.append(Alert(
                        type="http_rce", subtype="command_injection",
                        severity="CRITICAL", confidence="high",
                        source_ip=src, dest_ip=dst, port=tcp.dport,
                        http_method=method, http_uri=uri[:256],
                        detail=f"RCE / Command Injection détectée : {uri[:80]}",
                    ))
                    break

        return alerts


