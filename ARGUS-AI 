# SECTION 20 — LIGHTGBM CORRELATION MODEL
# ══════════════════════════════════════════════════════════════════════════════

class LGBMCorrelationModel:
    SEV  = {"LOW":1,"MEDIUM":2,"HIGH":3,"CRITICAL":4}
    CONF = {"low":1,"medium":2,"high":3}

    def __init__(self, config, db):
        self.cfg    = config; self.db = db
        self.log    = logging.getLogger("ARGUS.LGBM")
        self.model  = None
        self.enabled = config.get("enabled", True) and LGBM_OK and NP_OK
        self._cnt   = 0
        self._every = config.get("retrain_every", 500)
        self._mpath = config.get("model_path", "models/lgbm_correlation.pkl")
        self._thresh = config.get("risk_thresholds",
                                  {"MONITOR":0.3,"ALERT":0.55,"BLOCK_IP":0.75,"ISOLATE":0.90})
        self._ip_hist: Dict[str, deque] = defaultdict(lambda: deque(maxlen=500))
        if self.enabled: self._load()

    def _feats(self, alert: Alert) -> Optional[List[float]]:
        if not NP_OK: return None
        ip = alert.source_ip or "?"; now = time.time()
        h  = self._ip_hist.get(ip, deque())
        c5  = sum(1 for ts,_,_ in h if now-ts<300)
        c1h = sum(1 for ts,_,_ in h if now-ts<3600)
        t5  = len(set(t for ts,t,_ in h if now-ts<300))
        p5  = len(set(p for ts,_,p in h if now-ts<300 and p))
        ts_dt = datetime.utcfromtimestamp(alert.timestamp)
        tod   = ts_dt.hour + ts_dt.minute/60.0
        return [
            self.SEV.get(alert.severity,1), self.CONF.get(alert.confidence,1),
            min(c5,50), min(c1h,200), min(t5,10), min(p5,20),
            math.sin(2*math.pi*tod/24), math.cos(2*math.pi*tod/24),
            FastMath.entropy_str(alert.domain or ""), alert.entropy or 0.0,
            alert.geo_risk, 1.0 if alert.threat_intel else 0.0,
        ]

    def score(self, alert: Alert) -> float:
        ip = alert.source_ip or "?"
        self._ip_hist[ip].append((alert.timestamp, alert.type, alert.port))
        self._cnt += 1
        if self._cnt % self._every == 0:
            threading.Thread(target=self._train, daemon=True, name="LGBM-Train").start()
        if not (self.enabled and self.model):
            return self._heur(alert)
        f = self._feats(alert)
        if f is None: return self._heur(alert)
        try:
            return float(max(0.0, min(1.0, self.model.predict(
                np.array(f, dtype=np.float32).reshape(1,-1))[0])))
        except Exception: return self._heur(alert)

    def _heur(self, alert: Alert) -> float:
        base  = self.SEV.get(alert.severity,1)/4.0*0.6
        conf  = self.CONF.get(alert.confidence,1)/3.0*0.2
        geo   = alert.geo_risk * 0.1
        ti    = 0.1 if alert.threat_intel else 0.0
        return min(1.0, base + conf + geo + ti)

    def action_from_score(self, s: float) -> str:
        t = self._thresh
        if s >= t.get("ISOLATE",0.90): return "ISOLATE"
        if s >= t.get("BLOCK_IP",0.75): return "BLOCK_IP"
        if s >= t.get("ALERT",0.55): return "ALERT"
        return "MONITOR"

    def _train(self) -> None:
        if not (self.enabled and LGBM_OK and NP_OK): return
        res = self.db.export_training_data()
        if res is None: return
        X, y = res
        if len(X) < self.cfg.get("min_train_rows",50): return
        try:
            m = lgb.LGBMRegressor(objective="regression",num_leaves=63,
                learning_rate=0.03,n_estimators=300,subsample=0.8,
                colsample_bytree=0.8,n_jobs=4,verbose=-1)
            m.fit(X, y); self.model = m
            Path(self._mpath).parent.mkdir(parents=True, exist_ok=True)
            with open(self._mpath,"wb") as f: pickle.dump(m, f)
            self.log.info("LGBM entraîné (%d samples)", len(X))
        except Exception as e: self.log.error("LGBM train : %s", e)

    def _load(self):
        if not Path(self._mpath).exists(): return
        try:
            with open(self._mpath,"rb") as f: self.model = pickle.load(f)
            self.log.info("LGBM chargé : %s", self._mpath)
        except Exception as e: self.log.warning("LGBM load : %s", e)

    def train_from_db(self): self._train()


