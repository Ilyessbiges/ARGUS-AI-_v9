class DNSBeaconDetector:
    WHITELIST = frozenset({
        "google.com","microsoft.com","apple.com","cloudflare.com",
        "akamai.com","fastly.com","amazonaws.com","azure.com",
        "googleapiscom","gstatic.com","googleapis.com",
    })
    def __init__(self, config):
        t = config.get("thresholds", {})
        self.min_iv = t.get("dns_beacon_interval_min", 5)
        self.max_iv = t.get("dns_beacon_interval_max", 20)
        self.min_n  = t.get("dns_beacon_min_samples", 5)
        self.hist: Dict[str, deque] = defaultdict(lambda: deque(maxlen=120))
        self.log = logging.getLogger("ARGUS.DNS")

    def analyze(self, domain: str) -> Optional[Alert]:
        root = ".".join(domain.split(".")[-2:])
        if root in self.WHITELIST: return None
        now = time.time(); self.hist[domain].append(now)
        ts  = list(self.hist[domain])
        if len(ts) < self.min_n: return None
        ivs = [ts[i]-ts[i-1] for i in range(1,len(ts))]
        avg = sum(ivs)/len(ivs)
        std = (sum((x-avg)**2 for x in ivs)/len(ivs))**0.5
        cv  = std/avg if avg > 0 else 1.0
        if self.min_iv < avg < self.max_iv:
            conf = "high" if cv < 0.15 else "medium"
            return Alert(type="dns_beaconing",
                severity="HIGH" if conf=="high" else "MEDIUM",
                confidence=conf, domain=domain,
                detail=f"Beaconing DNS | avg={avg:.1f}s cv={cv:.3f} n={len(ts)}")
        return None


class TLSAnalyzer:
    MALICIOUS_JA3 = frozenset({
        "e7d705a3286e19ea42f587b344ee6865",  # Cobalt Strike
        "a0e9f5d64349fb13191bc781f81f42e1",  # Meterpreter
        "6bea65232c1288defa4bf058f5e99601",  # Dridex
        "51c64c77e60f3980eea90869b68c58a8",  # Trickbot
        "72a589da586844d7f0818ce684948eea",  # Emotet
        "d0ec4b50a944b182f66484f0fea58b5c",  # QakBot
    })
    KNOWN_GOOD = frozenset({"modern_browser_tls","chrome_tls_1.3",
                            "firefox_tls_1.3","safari_tls_1.3"})

    def compute_ja3(self, pkt) -> Optional[str]:
        if not (SCAPY_OK and pkt.haslayer(TCP) and pkt.haslayer(Raw)): return None
        try:
            v, c, e = FastMath.parse_ja3(bytes(pkt[Raw].load))
            return f"{v},{c},{e}" if v else None
        except Exception: return None

    def analyze(self, fp: str, pkt=None) -> Optional[Alert]:
        if pkt:
            raw = self.compute_ja3(pkt)
            if raw: fp = hashlib.md5(raw.encode()).hexdigest()
        if fp in self.KNOWN_GOOD: return None
        sev  = "CRITICAL" if fp in self.MALICIOUS_JA3 else "LOW"
        conf = "high" if sev == "CRITICAL" else "low"
        detail = ("JA3 C2 connu (Cobalt Strike/Meterpreter/Emotet)" if sev=="CRITICAL"
                  else "Bibliothèque TLS inconnue")
        return Alert(type="tls_anomaly", severity=sev, confidence=conf,
            fingerprint=fp, detail=detail)


class DGADetector:
    def __init__(self, model_path):
        self.model = None; self.log = logging.getLogger("ARGUS.DGA")
        if JOBLIB_OK and Path(model_path).exists():
            try: self.model = joblib.load(model_path)
            except Exception as e: self.log.error("DGA model : %s", e)

    def _feats(self, domain):
        label = domain.split(".")[0]
        return [len(label), FastMath.entropy_str(label), label.count("-"),
                sum(c.isdigit() for c in label), FastMath.consonant_ratio(label),
                len(re.findall(r"[0-9]{3,}", label))]

    def _heur(self, domain):
        label = domain.split(".")[0]
        return (len(label)>15 and FastMath.entropy_str(label)>3.5
                and FastMath.consonant_ratio(label)>0.72)

    def analyze(self, domain):
        f = self._feats(domain)
        is_dga = bool(self.model.predict([f])[0]==1) if self.model else self._heur(domain)
        if is_dga:
            ent = round(f[1], 3)
            return Alert(type="dga_domain", severity="HIGH",
                confidence="high" if self.model else "medium",
                domain=domain, entropy=ent,
                detail=f"Domaine DGA (entropie={ent}, len={len(domain.split('.')[0])})")
        return None


class YaraScanner:
    def __init__(self, rules_path):
        self.rules = None; self._lock = threading.Lock()
        self.log = logging.getLogger("ARGUS.YARA")
        if YARA_OK and Path(rules_path).exists():
            try: self.rules = yara.compile(filepath=str(rules_path))
            except yara.SyntaxError as e: self.log.error("YARA : %s", e)

    def add_rule(self, text):
        if not YARA_OK or not text: return False
        if any(bad in text for bad in ("import ","include ","__")): return False
        try:
            c = yara.compile(source=text)
            with self._lock: self.rules = c; return True
        except yara.SyntaxError: return False

    def scan(self, payload):
        if not self.rules: return []
        try:
            with self._lock: return [m.rule for m in self.rules.match(data=payload)]
        except Exception: return []


class BufferOverflowDetector:
    def __init__(self, config):
        t = config.get("thresholds", {})
        self.limits = t.get("payload_size", {"80":8192,"443":16384,"default":4096})
        self.ent_th = t.get("high_entropy", 7.8)

    def analyze(self, pkt):
        if not (SCAPY_OK and pkt.haslayer(IP) and pkt.haslayer(Raw)): return []
        pl = bytes(pkt[Raw].load)
        src = pkt[IP].src; dst = pkt[IP].dst
        dp  = pkt[TCP].dport if pkt.haslayer(TCP) else 0
        lim = int(self.limits.get(str(dp)) or self.limits.get("default",4096))
        ent = FastMath.entropy_bytes(pl)
        alerts = []
        if len(pl) > lim:
            alerts.append(Alert(type="buffer_overflow",subtype="oversized",
                severity="HIGH",confidence="medium",source_ip=src,dest_ip=dst,port=dp,
                payload_len=len(pl),detail=f"Payload {len(pl)}B > limite {lim}B"))
        if ent > self.ent_th:
            alerts.append(Alert(type="buffer_overflow",subtype="high_entropy",
                severity="HIGH",confidence="medium",source_ip=src,dest_ip=dst,port=dp,
                entropy=round(ent,3),detail=f"Entropie payload {ent:.3f} > {self.ent_th}"))
        if FastMath.nop_sled(pl):
            alerts.append(Alert(type="buffer_overflow",subtype="nop_sled",
                severity="CRITICAL",confidence="high",source_ip=src,dest_ip=dst,port=dp,
                detail="NOP sled détecté — shellcode x86/x64"))
        return alerts


class BackdoorDetector:
    RAT_PORTS     = frozenset({4444,1337,31337,9001,9002,8443,6666,5555,7777,55555})
    SHELL_MARKERS = frozenset({b"/bin/sh",b"/bin/bash",b"cmd.exe",b"powershell",b"netcat",b"nc -e",b"bash -i"})

    def analyze(self, pkt):
        if not (SCAPY_OK and pkt.haslayer(IP) and pkt.haslayer(TCP)): return []
        src=pkt[IP].src; dst=pkt[IP].dst; dp=pkt[TCP].dport; sp=pkt[TCP].sport
        alerts = []
        sp_ = dp if dp in self.RAT_PORTS else (sp if sp in self.RAT_PORTS else None)
        if sp_:
            alerts.append(Alert(type="backdoor_behavior",subtype="rat_port",
                severity="HIGH",confidence="medium",source_ip=src,dest_ip=dst,port=sp_,
                detail=f"Port RAT connu {sp_}"))
        if pkt.haslayer(Raw):
            pl = bytes(pkt[Raw].load)
            for kw in self.SHELL_MARKERS:
                if kw in pl:
                    alerts.append(Alert(type="backdoor_behavior",subtype="shell_keyword",
                        severity="CRITICAL",confidence="high",source_ip=src,dest_ip=dst,
                        detail=f"Mot-clé shell '{kw.decode()}' dans payload"))
                    break
        return alerts


